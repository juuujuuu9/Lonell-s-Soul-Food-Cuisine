# Database
DATABASE_URL="postgresql://user:password@host:5432/neondb"

# Clerk Authentication
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Twilio SMS
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_FROM_NUMBER="+14242958020"

# Feature Flags
SMS_ENABLED="false"

# Cron (Vercel sends Authorization: Bearer <CRON_SECRET> on scheduled requests)
CRON_SECRET="generate-a-long-random-string"

# Reputation
GOOGLE_REVIEW_URL="https://www.google.com/search?q=Lonell%27s+%7C+Soul+Food+Cuisine+Reviews"

# Site
PUBLIC_SITE_URL="https://lonellssoulfood.com"
