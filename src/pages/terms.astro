---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import {
  LOYALTY_KEYWORD,
  LOYALTY_SMS_DISPLAY,
  PROMO_VALID_DAYS,
} from "../data/business";
import { LOYALTY_MESSAGE_FREQUENCY, LOYALTY_PROGRAM_NAME } from "../data/loyalty-consent";
---

<BaseLayout title="Terms of Service" noindex description="Terms of Service for Lonell's Soul Food Cuisine website and SoulFood SMS Club messaging program.">
  <div class="min-h-screen pb-16">
    <Section eyebrow="Legal" title="Terms of Service" description="Last updated: June 2026">
      <div class="mt-12 max-w-3xl mx-auto text-sm text-[var(--color-text-secondary)] leading-relaxed space-y-6">
        <p>
          These Terms of Service ("Terms") govern your use of the Lonell&apos;s Soul Food Cuisine website
          at lonellssoulfood.com and related services operated by Lonell&apos;s Soul Food Cuisine
          ("we," "our," or "us"). By using our website or opting into our SMS program, you agree to these Terms.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Use of Website</h3>
        <p>
          Our website provides information about our restaurant, menu, hours, events, and contact options.
          You may use the site for lawful personal purposes only. You agree not to misuse the site, attempt
          unauthorized access, or interfere with its operation.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Reservations &amp; In-Person Services</h3>
        <p>
          Menu items, prices, hours, and event schedules may change without notice. Offers described on
          the website or in SMS messages are subject to availability and any stated expiration dates.
          Consent to receive SMS messages is not required as a condition of purchase.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Intellectual Property</h3>
        <p>
          All content on this website — including text, images, logos, and design — is owned by
          Lonell&apos;s Soul Food Cuisine or used with permission. You may not copy, reproduce, or
          distribute our content without prior written consent.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Disclaimer</h3>
        <p>
          The website and its content are provided "as is" without warranties of any kind. To the fullest
          extent permitted by law, we are not liable for indirect, incidental, or consequential damages
          arising from your use of the website or SMS program.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Changes</h3>
        <p>
          We may update these Terms at any time. Continued use of the website or SMS program after changes
          are posted constitutes acceptance of the revised Terms.
        </p>

        <h3
          id="sms-program"
          class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3 scroll-mt-24"
        >
          SMS Messaging Program ({LOYALTY_PROGRAM_NAME})
        </h3>
        <p>
          By opting into the {LOYALTY_PROGRAM_NAME}, you agree to the SMS terms in this section in
          addition to the general Terms above.
        </p>

        <h4 class="font-semibold text-[var(--color-text-primary)] mt-6 mb-2">Program Description</h4>
        <p>
          The {LOYALTY_PROGRAM_NAME} sends recurring automated text messages including exclusive offers,
          menu previews, event invitations, and promotional content. Message frequency varies but {LOYALTY_MESSAGE_FREQUENCY}.
        </p>

        <h4 class="font-semibold text-[var(--color-text-primary)] mt-6 mb-2">How to Opt In</h4>
        <p>We offer two ways to join:</p>
        <ol class="list-decimal pl-6 space-y-3 mt-2">
          <li>
            <strong class="text-[var(--color-text-primary)]">Text keyword:</strong> Text {LOYALTY_KEYWORD} to{" "}
            {LOYALTY_SMS_DISPLAY}. Sending the keyword constitutes your consent to receive SMS messages.
          </li>
          <li>
            <strong class="text-[var(--color-text-primary)]">QR code or website:</strong> Scan a QR code at our
            restaurant or visit{" "}
            <a href="/join" class="text-[var(--color-accent)] hover:underline">lonellssoulfood.com/join</a>.
            Review the consent disclosure, then tap the button to open a pre-filled text message to{" "}
            {LOYALTY_SMS_DISPLAY}. Sending {LOYALTY_KEYWORD} completes your opt-in. The same consent
            disclosure appears in a popup before the messaging app opens on our main website.
          </li>
        </ol>
        <p class="mt-3">
          After opt-in, you receive a welcome message confirming enrollment. New members may show the
          welcome text for 10% off a dinner within {PROMO_VALID_DAYS} days of joining.
        </p>

        <h4 class="font-semibold text-[var(--color-text-primary)] mt-6 mb-2">Opt-Out &amp; Help</h4>
        <p>
          Reply <strong>STOP</strong> to any message to unsubscribe. You will receive a confirmation that
          you have been unsubscribed and will no longer receive SMS messages from us. Reply <strong>HELP</strong>{" "}
          for assistance. You may rejoin at any time by texting {LOYALTY_KEYWORD} again.
        </p>

        <h4 class="font-semibold text-[var(--color-text-primary)] mt-6 mb-2">Message &amp; Data Rates</h4>
        <p>
          Message and data rates may apply. Contact your mobile carrier for pricing details. We are not
          responsible for charges from your mobile carrier.
        </p>

        <h4 class="font-semibold text-[var(--color-text-primary)] mt-6 mb-2">Supported Carriers</h4>
        <p>
          Supported carriers include but are not limited to: AT&amp;T, Verizon, T-Mobile, Sprint, Boost,
          Cricket, MetroPCS, U.S. Cellular, and others. Carriers are not liable for delayed or undelivered messages.
        </p>

        <h4 class="font-semibold text-[var(--color-text-primary)] mt-6 mb-2">SMS Privacy</h4>
        <p>
          Your phone number and SMS-related information will not be sold, rented, or shared with third
          parties for their marketing purposes. See our{" "}
          <a href="/privacy" class="text-[var(--color-accent)] hover:underline">Privacy Policy</a> for details.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Contact</h3>
        <p>
          For questions about these Terms or the SMS program, contact us at{" "}
          <a href="tel:+13234513104" class="text-[var(--color-accent)] hover:underline">(323) 451-3104</a>
          or{" "}
          <a href="mailto:reservations@lonellssoulfood.com" class="text-[var(--color-accent)] hover:underline">reservations@lonellssoulfood.com</a>.
        </p>
        <p>
          Lonell&apos;s Soul Food Cuisine<br />
          8501 S Vermont Ave<br />
          Los Angeles, CA 90044
        </p>
      </div>
    </Section>
  </div>
</BaseLayout>
