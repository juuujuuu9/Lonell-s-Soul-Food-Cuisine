---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
---

<!-- Review + AggregateRating schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AggregateRating",
  "itemReviewed": {
    "@type": "Restaurant",
    "name": "Lonell's Soul Food Cuisine"
  },
  "ratingValue": "4.3",
  "reviewCount": "186",
  "bestRating": "5"
})}></script>

<BaseLayout title="Reviews & Press" description="See what everyone's saying about Lonell's Soul Food Cuisine. Rated 4.3 stars across Yelp and Google with 186+ reviews. Read reviews and press mentions.">
  <div class="min-h-screen pb-16">
    <Section eyebrow="Word on the Street" title="Rated 4.3 Stars Across Yelp &amp; Google" description="186+ reviews and counting. Here's what our guests are saying on Yelp and Google about the food, the music, and the experience.">

      <div class="mt-8 mb-8 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-lg mx-auto">
        <!-- Yelp -->
        <a href="https://www.yelp.com/biz/lonells-soul-food-cuisine-los-angeles" target="_blank" rel="noopener noreferrer" class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] flex flex-col items-center gap-3 hover:bg-[var(--color-surface-hover)] transition-colors">
          <svg viewBox="-6 0 48 48" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" class="w-10 h-10" fill="#D32200">
            <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
              <g transform="translate(-306.000000, -760.000000)" fill="#D32200">
                <path d="M306.916951,783.108522 C306.149772,784.358008 305.82659,788.292467 306.090874,790.903939 C306.184506,791.76643 306.338546,792.484922 306.560545,792.913918 C306.867115,793.506411 307.383601,793.860408 307.972577,793.879907 C308.350126,793.900907 308.584206,793.834908 315.676081,791.517432 C315.676081,791.517432 318.827857,790.497443 318.841449,790.489943 C319.62675,790.288945 320.155318,789.553953 320.208175,788.614963 C320.258012,787.654973 319.768709,786.804482 318.963775,786.498486 C318.963775,786.498486 316.743788,785.577496 316.737748,785.577496 C309.117305,782.384029 308.776001,782.258031 308.390901,782.253531 C307.803435,782.231031 307.277888,782.531028 306.916951,783.108522 Z M323.965238,806.903819 C324.089074,806.542323 324.102665,806.291825 324.123808,798.721406 C324.123808,798.721406 324.141931,795.377941 324.143441,795.341942 C324.193277,794.52445 323.67377,793.778958 322.81598,793.441462 C321.935536,793.097966 320.988644,793.310963 320.457055,793.985956 C320.457055,793.985956 318.903065,795.860936 318.897024,795.860936 C313.555465,802.231369 313.336487,802.525365 313.2051,802.903361 C313.12657,803.128359 313.093346,803.362357 313.122039,803.597854 C313.153753,803.93385 313.301752,804.269847 313.552445,804.578844 C314.789294,806.075828 320.72738,808.295804 322.622675,807.967308 C323.28263,807.844309 323.759851,807.467813 323.965238,806.903819 Z M336.006625,804.269547 C337.796206,803.545055 341.703079,798.497608 341.977935,796.555129 C342.071567,795.880136 341.86467,795.296642 341.405571,794.926146 C341.106553,794.696649 340.873983,794.60665 333.788149,792.244175 C333.788149,792.244175 330.680168,791.200186 330.639393,791.180686 C329.888826,790.885189 329.028015,791.156686 328.45112,791.884179 C327.853083,792.626671 327.759451,793.60316 328.238183,794.345652 L329.490134,796.41413 C333.699047,803.357557 334.019208,803.848051 334.322758,804.088049 C334.790918,804.463045 335.385935,804.524544 336.006625,804.269547 Z M332.347423,786.397837 C340.401292,784.416358 340.712392,784.309859 341.031043,784.098361 C341.517326,783.766865 341.761977,783.207371 341.721202,782.526378 C341.721202,782.503878 341.724222,782.482878 341.721202,782.457379 C341.514305,780.4504 338.046898,775.221456 336.340378,774.373965 C335.7363,774.078468 335.129202,774.099467 334.630837,774.439964 C334.319737,774.646962 334.088677,774.957458 329.777071,780.948395 C329.777071,780.948395 327.82741,783.646866 327.804757,783.672366 C327.289781,784.305359 327.28525,785.217349 327.785124,785.997341 C328.304631,786.804332 329.183565,787.197328 329.988499,786.970831 C329.988499,786.970831 329.955274,787.02783 329.946213,787.03983 C330.343394,786.885332 331.054696,786.709833 332.347423,786.397837 Z M324.258669,779.640709 C324.121241,776.399243 323.162267,761.957396 323.049003,761.286904 C322.882881,760.68241 322.419251,760.248915 321.747215,760.076416 C319.69335,759.557422 311.835806,761.796898 310.378468,763.323882 C309.911818,763.818877 309.736636,764.43087 309.877084,764.969364 C310.105123,765.449359 319.844369,781.013194 319.844369,781.013194 C321.285095,783.384669 322.458516,783.017173 322.842106,782.895674 C323.224185,782.774175 324.391566,782.406679 324.258669,779.640709 Z" id="Yelp"></path>
              </g>
            </g>
          </svg>
          <div class="flex items-center gap-1 text-[var(--color-accent)] text-xl">
            {"★".repeat(4)}
            <span class="text-[var(--color-text-muted)]">★</span>
          </div>
          <span class="text-sm text-[var(--color-text-muted)]">4.2 / 5.0 &middot; 139 reviews</span>
        </a>

        <!-- Google -->
        <a href="https://www.google.com/search?sca_esv=53821e7f56e2e48d&rlz=1C5OZZY_enUS1161US1161&sxsrf=ANbL-n7utMfsTstt-odNoLclFLa0DXOipw:1781028431538&si=AL3DRZEsmMGCryMMFSHJ3StBhOdZ2-6yYkXd_doETEE1OR-qOfArl6PK_L9tsvHRQwagnYOqN3MTB0y450gIwH2n0fgkW-TxORs8fdAtuHy82qvVnSpNQ-yg6coA9ySBLOqDEbMc_GA0CcSVXU3PVNjqOg_xHb3_Rg%3D%3D&q=Lonell%27s+%7C+Soul+Food+Cuisine+Reviews&sa=X&ved=2ahUKEwj8rvz33_qUAxWXJEQIHb7pMlQQ0bkNegQIIxAF&cshid=1781028472941673&biw=1711&bih=805&dpr=1.1" target="_blank" rel="noopener noreferrer" class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] flex flex-col items-center gap-3 hover:bg-[var(--color-surface-hover)] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="w-10 h-10">
            <g transform="translate(1.4065934065934016 1.4065934065934016) scale(2.81 2.81)">
              <circle cx="45" cy="45" r="45" style="fill: rgb(255,255,255);" />
              <path d="M 74 45.658 c 0 -2.433 -0.197 -4.209 -0.625 -6.05 H 45.592 v 10.982 H 61.9 c -0.329 2.729 -2.104 6.839 -6.05 9.601 l -0.055 0.368 l 8.785 6.805 l 0.609 0.061 C 70.778 62.262 74 54.667 74 45.658" style="fill: rgb(66,133,244);" />
              <path d="M 45.592 74.592 c 7.99 0 14.697 -2.631 19.596 -7.168 L 55.85 60.19 c -2.499 1.743 -5.853 2.959 -10.258 2.959 c -7.825 0 -14.467 -5.162 -16.835 -12.297 l -0.347 0.029 l -9.134 7.069 l -0.119 0.332 C 24.023 67.95 34.018 74.592 45.592 74.592" style="fill: rgb(52,168,83);" />
              <path d="M 28.757 50.853 c -0.625 -1.841 -0.986 -3.814 -0.986 -5.853 c 0 -2.039 0.362 -4.011 0.953 -5.853 l -0.017 -0.392 l -9.249 -7.183 l -0.303 0.144 C 17.151 35.728 16 40.232 16 45 s 1.151 9.272 3.156 13.283 L 28.757 50.853" style="fill: rgb(251,188,5);" />
              <path d="M 45.592 26.85 c 5.557 0 9.305 2.4 11.442 4.406 l 8.351 -8.154 c -5.129 -4.768 -11.804 -7.694 -19.794 -7.694 c -11.574 0 -21.569 6.642 -26.435 16.308 l 9.568 7.431 C 31.125 32.012 37.766 26.85 45.592 26.85" style="fill: rgb(235,67,53);" />
            </g>
          </svg>
          <div class="flex items-center gap-1 text-[var(--color-accent)] text-xl">
            {"★".repeat(4)}
            <span class="text-[var(--color-text-muted)]">★</span>
          </div>
          <span class="text-sm text-[var(--color-text-muted)]">4.4 / 5.0 &middot; 47 reviews</span>
        </a>
      </div>
    </Section>

    <!-- Featured Reviews -->
    <section class="section-padding bg-[var(--color-surface-card)]">
      <div class="max-w-4xl mx-auto">
        <h3 class="font-display text-2xl font-semibold mb-8 text-center" data-reveal>What Guests Are Saying</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Yelp -->
          <div class="p-6 bg-[var(--color-surface-base)] rounded-xl border border-[var(--color-border-subtle)]">
            <div class="flex items-center gap-2 mb-3">
              <div class="flex items-center gap-1 text-[var(--color-accent)]">
                {"★".repeat(5)}
              </div>
              <span class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)]">Yelp</span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 italic">"This will be the new spot to catch up with my friend! We both ordered oxtails; divine tender well seasoned."</p>
            <p class="text-xs text-[var(--color-text-muted)]">— Yelp review</p>
          </div>

          <!-- Google -->
          <div class="p-6 bg-[var(--color-surface-base)] rounded-xl border border-[var(--color-border-subtle)]">
            <div class="flex items-center gap-2 mb-3">
              <div class="flex items-center gap-1 text-[var(--color-accent)]">
                {"★".repeat(5)}
              </div>
              <span class="text-[10px] uppercase tracking-widest text-[var(--color-neon)]">Google</span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 italic">"Absolutely Delightful! Parking a breeze on the street."</p>
            <p class="text-xs text-[var(--color-text-muted)]">— Google review</p>
          </div>

          <!-- Yelp -->
          <div class="p-6 bg-[var(--color-surface-base)] rounded-xl border border-[var(--color-border-subtle)]">
            <div class="flex items-center gap-2 mb-3">
              <div class="flex items-center gap-1 text-[var(--color-accent)]">
                {"★".repeat(5)}
              </div>
              <span class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)]">Yelp</span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 italic">"Met my foodie friend there and we were completely pleased with the service, the music, the food."</p>
            <p class="text-xs text-[var(--color-text-muted)]">— Yelp review</p>
          </div>

          <!-- Google -->
          <div class="p-6 bg-[var(--color-surface-base)] rounded-xl border border-[var(--color-border-subtle)]">
            <div class="flex items-center gap-2 mb-3">
              <div class="flex items-center gap-1 text-[var(--color-accent)]">
                {"★".repeat(5)}
              </div>
              <span class="text-[10px] uppercase tracking-widest text-[var(--color-neon)]">Google</span>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 italic">"The food was divine. The oxtails were fall-off-the-bone tender. Great service and atmosphere too."</p>
            <p class="text-xs text-[var(--color-text-muted)]">— Google review</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Review Themes -->
    <Section eyebrow="What People Love" title="Review Highlights">
      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] text-center">
          <span class="font-display text-4xl font-bold text-[var(--color-accent)]">🥩</span>
          <h3 class="font-display text-lg font-semibold mt-3 mb-2">Oxtails</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">Frequently mentioned as the standout dish — "fall-off-the-bone" tender and well-seasoned.</p>
        </div>
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] text-center">
          <span class="font-display text-4xl font-bold text-[var(--color-accent)]">🎵</span>
          <h3 class="font-display text-lg font-semibold mt-3 mb-2">Live Music</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">Guests love the live jazz and karaoke nights — a unique experience for a soul food spot.</p>
        </div>
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] text-center">
          <span class="font-display text-4xl font-bold text-[var(--color-accent)]">🚗</span>
          <h3 class="font-display text-lg font-semibold mt-3 mb-2">Easy Parking</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">"Parking a breeze on the street" — a rare find in LA that guests consistently appreciate.</p>
        </div>
      </div>
    </Section>

    <!-- Press Mentions -->
    <section class="section-padding bg-[var(--color-surface-card)]">
      <div class="max-w-4xl mx-auto text-center">
        <span class="eyebrow" data-reveal>As Seen In</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-8" data-reveal>Press & Media</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-8 bg-[var(--color-surface-base)] rounded-xl border border-[var(--color-border-subtle)] text-left">
            <div class="flex items-center justify-start gap-4 mb-4">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-text-muted)] shrink-0">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
              </svg>
              <h3 class="font-display text-xl font-semibold" data-reveal>The Infatuation</h3>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 italic">
              "This sit-down soul food spot in Vermont Knolls is cooking platters of fried chicken, catfish, oxtail, and ribs, all served with a choice of sides like mac and cheese, collard greens, baked beans, and cornbread. There's live jazz on certain nights, free champagne during Sunday brunch, and a dessert lineup that includes pound cake, banana pudding, and peach cobbler."
            </p>
            <p class="text-xs text-[var(--color-text-muted)] mb-3">
              — Cathy Park, <em>Senior Staff Writer</em> &middot; July 2025
            </p>
            <a href="https://www.theinfatuation.com/los-angeles/reviews/lonell-s-soul-food-cuisine" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-xs text-[var(--color-accent)] hover:underline">
              Read full review &rarr;
            </a>
          </div>

          <div class="p-8 bg-[var(--color-surface-base)] rounded-xl border border-[var(--color-border-subtle)] text-left">
            <div class="flex items-center justify-start gap-4 mb-4">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-text-muted)] shrink-0">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
              </svg>
              <h3 class="font-display text-xl font-semibold" data-reveal>Eater LA</h3>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 italic">
              "Lonell's Soul Food Cuisine opened in mid-May in Vermont Knolls, bringing a new destination for oxtails and macaroni and cheese to the neighborhood. Other soul food staples like fried chicken and fried catfish can be paired with sides like collard greens, yams, cornbread, and more. Save room for lemon cake, pound cake, peach cobbler, or banana pudding for dessert."
            </p>
            <p class="text-xs text-[var(--color-text-muted)] mb-3">
              — Rebecca Roland, <em>Deputy Editor</em> &middot; June 2025
            </p>
            <a href="https://la.eater.com/2025/5/29/285623/best-new-restaurants-hidden-gems-los-angeles-openings-june-2025" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-xs text-[var(--color-accent)] hover:underline">
              Read full article &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof -->
    <Section eyebrow="Join the Community" title="@lonellssoulfood">
      <p class="text-[var(--color-text-secondary)] mb-8 max-w-xl">
        Follow us on Instagram for daily specials, event announcements, and behind-the-scenes looks at what's cooking. 
        7,400+ followers and growing.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="https://www.instagram.com/lonellssoulfood/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-2.5 bg-[var(--color-accent)] text-black font-semibold text-sm rounded-full hover:bg-[var(--color-accent-hover)] transition-colors">
          Follow on Instagram
        </a>
        <a href="https://yelp.com/biz/lonells-soul-food-cuisine-los-angeles" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-2.5 border border-[var(--color-border)] text-[var(--color-text-primary)] text-sm rounded-full hover:bg-[var(--color-surface-hover)] transition-colors">
          Read Yelp Reviews
        </a>
        <a href="https://search.google.com/local/writereview?placeid=PLACE_ID" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-2.5 border border-[var(--color-border)] text-[var(--color-text-primary)] text-sm rounded-full hover:bg-[var(--color-surface-hover)] transition-colors">
          Leave a Google Review
        </a>
        <a href="https://facebook.com/lonellssoulfoodcuisine" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-6 py-2.5 border border-[var(--color-border)] text-[var(--color-text-primary)] text-sm rounded-full hover:bg-[var(--color-surface-hover)] transition-colors">
          Follow on Facebook
        </a>
      </div>
    </Section>
  </div>
</BaseLayout>
