---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
---

<BaseLayout title="SMS Terms & Conditions" description="Terms and conditions for Lonell's Soul Food Cuisine SMS messaging program.">
  <div class="min-h-screen pb-16">
    <Section eyebrow="Legal" title="SMS Terms & Conditions" description="Last updated: June 2026">
      <div class="mt-12 max-w-3xl mx-auto text-sm text-[var(--color-text-secondary)] leading-relaxed space-y-6">
        <p>
          By opting into the Lonell's Soul Food Cuisine SMS program ("SoulFood SMS Club"), you agree to
          these terms and conditions.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Program Description</h3>
        <p>
          The SoulFood SMS Club sends recurring text messages including exclusive offers, menu previews,
          event invitations, and promotional content. Message frequency varies but typically ranges from
          2 to 4 messages per month.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Opt-In</h3>
        <p>
          By providing your phone number and opting in, you consent to receive automated SMS messages from
          Lonell's Soul Food Cuisine. Consent is not required as a condition of purchase. You may opt out
          at any time.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Opt-Out</h3>
        <p>
          Reply <strong>STOP</strong> to any message to unsubscribe. You will receive a confirmation message
          that you have been unsubscribed. After that, you will no longer receive SMS messages from us.
          Reply <strong>HELP</strong> for assistance.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Rates</h3>
        <p>
          Message and data rates may apply. Contact your mobile carrier for pricing details. We are not
          responsible for any charges from your mobile carrier.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Supported Carriers</h3>
        <p>
          Supported carriers include but are not limited to: AT&T, Verizon, T-Mobile, Sprint, Boost,
          Cricket, MetroPCS, U.S. Cellular, and others. Carriers are not liable for delayed or
          undelivered messages.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Privacy</h3>
        <p>
          Your phone number and personal information will not be sold, rented, or shared with third
          parties for their marketing purposes. See our <a href="/privacy" class="text-[var(--color-accent)] hover:underline">Privacy Policy</a>
          for more details.
        </p>

        <h3 class="font-display text-lg font-semibold text-[var(--color-text-primary)] mt-8 mb-3">Contact</h3>
        <p>
          For questions or assistance, contact us at <a href="tel:+13234513104" class="text-[var(--color-accent)] hover:underline">(323) 451-3104</a>
          or <a href="mailto:reservations@lonells.com" class="text-[var(--color-accent)] hover:underline">reservations@lonells.com</a>.
        </p>
      </div>
    </Section>
  </div>
</BaseLayout>
