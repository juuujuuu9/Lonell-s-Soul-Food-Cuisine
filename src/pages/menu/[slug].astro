---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { dishes, getDishBySlug } from "../../data/menu";

export function getStaticPaths() {
  return dishes.map((dish) => ({
    params: { slug: dish.slug },
    props: { dish },
  }));
}

const { dish } = Astro.props;
const imageSrc = dish.image || "/media/images/wide-bar-lg.webp";
---

<BaseLayout title={dish.name} description={dish.seoDescription}>
  <!-- MenuItem Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MenuItem",
    "name": `${dish.name} — Lonell's Soul Food Cuisine`,
    "description": dish.longDescription,
    "offers": {
      "@type": "Offer",
      "price": dish.price ? dish.price.replace("$", "") : "",
      "priceCurrency": "USD",
    },
    "suitableForDiet": dish.dietaryTags.includes("Gluten-Free option") ? "https://schema.org/GlutenFreeDiet" : undefined,
  })}></script>

  <div class="min-h-screen pb-16">
    <!-- Hero section -->
    <div class="relative h-[40vh] md:h-[50vh] overflow-hidden bg-[var(--color-surface-card)]">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-brand-amber)]/10 to-transparent" />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-surface-base)] via-black/40 to-transparent" />
      <div class="absolute bottom-0 left-0 right-0 p-6 md:p-12">
        <div class="max-w-4xl mx-auto">
          <a href="/menu" class="inline-flex items-center gap-1.5 text-xs tracking-wider uppercase text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors mb-4">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12" />
              <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to Menu
          </a>
          <h1 class="font-display text-3xl md:text-5xl font-bold text-[var(--color-text-primary)]">{dish.name}</h1>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-4 md:px-8 -mt-8 relative z-10">
      <div class="bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] p-6 md:p-10">
        <!-- Price & Tags -->
        <div class="flex flex-wrap items-center gap-4 mb-6">
          {dish.price && (
            <span class="font-display text-2xl font-bold text-[var(--color-accent)]">{dish.price}</span>
          )}
          <span class="text-xs tracking-[0.15em] uppercase text-[var(--color-text-muted)] px-3 py-1 bg-[var(--color-surface-base)] rounded-full">{dish.category}</span>
          {dish.dietaryTags.map((tag) => (
            <span class="text-xs tracking-[0.1em] uppercase text-[var(--color-neon)] px-3 py-1 bg-[var(--color-neon-subtle)] rounded-full">{tag}</span>
          ))}
        </div>

        <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-8">{dish.longDescription}</p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-6 border-t border-[var(--color-border-subtle)]">
          <a
            href="tel:+13234513104"
            class="inline-flex items-center px-6 py-3 bg-[var(--color-brand-amber)] text-black font-bold text-sm rounded-full hover:bg-[var(--color-brand-amber-light)] transition-colors min-h-[48px]"
          >
            Order Now
          </a>
          <a
            href="tel:+13234513104"
            class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--color-border)] text-[var(--color-text-primary)] text-sm rounded-full hover:bg-[var(--color-surface-hover)] transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            Call (323) 451-3104
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
