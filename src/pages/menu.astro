---
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageLightboxGallery from "../components/ImageLightboxGallery.astro";
import Section from "../components/Section.astro";
import type { PageHeaderBackground } from "../components/PageHeader.astro";
import { foodPhotos } from "../data/menu";

interface MenuItem {
  name: string;
  description: string;
  price: string;
  slug?: string;
}

interface MenuSubtitle {
  mobile: string;
  desktop: string;
}

interface MenuCategory {
  name: string;
  subtitle: string | MenuSubtitle;
  items: MenuItem[];
}

const menuCategories: MenuCategory[] = [
  {
    name: "Dinner Plates",
    subtitle: "Served with 2 sides",
    items: [
      { name: "Baked Chicken", description: "Golden-brown, oven-roasted chicken", price: "$31.20", slug: "baked-chicken" },
      { name: "Fried Chicken", description: "Crispy, buttermilk-marinated fried chicken", price: "$31.20", slug: "fried-chicken" },
      { name: "Meatloaf", description: "Homestyle meatloaf, rich and savory, served with gravy", price: "$27.60", slug: "meatloaf" },
      { name: "Oxtails", description: "Slow-braised, fall-off-the-bone tender. Thursday–Sunday only.", price: "$42.00", slug: "oxtails" },
      { name: "Pork Chop", description: "Cooked to order, thick-cut and well-seasoned", price: "$31.20", slug: "pork-chops" },
      { name: "Turkey Chop", description: "Cooked to order — a lean, flavorful alternative", price: "$36.00", slug: "turkey-chop" },
      { name: "Catfish", description: "Crispy, Louisiana-style seasoned catfish", price: "$32.40", slug: "catfish" },
      { name: "Short Ribs", description: "Rich, braised short ribs. Friday & Saturday only.", price: "$36.00", slug: "short-ribs" },
      { name: "Brisket", description: "Tender, slow-smoked brisket, sliced and sauced", price: "$31.20", slug: "brisket" },
      { name: "Salmon", description: "Perfectly seasoned salmon fillet", price: "$32.40" },
    ],
  },
  {
    name: "A La Carte Proteins",
    subtitle: "No sides included",
    items: [
      { name: "Baked Chicken", description: "", price: "$18.00" },
      { name: "Fried Chicken", description: "", price: "$18.00" },
      { name: "Meatloaf", description: "", price: "$14.00" },
      { name: "Pork Chop", description: "Cooked to order", price: "$16.80" },
      { name: "Turkey Chop", description: "Cooked to order", price: "$19.20" },
      { name: "Catfish", description: "", price: "$20.40" },
      { name: "Short Ribs", description: "Fri & Sat only", price: "$24.00" },
      { name: "Brisket", description: "", price: "$21.60" },
    ],
  },
  {
    name: "Sides & Extras",
    subtitle: "",
    items: [
      { name: "String Beans", description: "Fresh green beans, Southern-style", price: "$7.20" },
      { name: "Mashed Potatoes", description: "Creamy, buttery mashed potatoes", price: "$7.20" },
      { name: "Collard Greens", description: "Slow-cooked with smoked turkey", price: "$9.60" },
      { name: "Cabbage", description: "Seasoned Southern-style cabbage", price: "$9.60" },
      { name: "Red Beans & Rice", description: "Cajun-style with Andouille sausage", price: "$10.80" },
      { name: "Mac and Cheese", description: "Five-cheese blend, baked golden", price: "$10.80" },
      { name: "Yams", description: "Candied yams, sweet and tender", price: "$10.80" },
      { name: "Hot Water Cornbread (2 pc)", description: "Crispy, golden cornmeal cakes", price: "$6.00" },
      { name: "Cornbread (1 pc)", description: "Classic Southern cornbread", price: "$4.20" },
    ],
  },
  {
    name: "Desserts",
    subtitle: "",
    items: [
      { name: "Pound Cake", description: "Classic buttery pound cake", price: "$6.00" },
      { name: "Banana Pudding", description: "Layers of vanilla wafers, fresh bananas, and homemade custard", price: "$7.20" },
      { name: "Peach Cobbler", description: "Southern-style, warm and spiced", price: "$8.40", slug: "peach-cobbler" },
    ],
  },
  {
    name: "Beverages",
    subtitle: "",
    items: [
      { name: "Soda", description: "Coke products", price: "$3.60" },
      { name: "Lemonade", description: "Fresh-squeezed", price: "$4.20" },
      { name: "Muddy Water", description: "House specialty beverage", price: "$4.80" },
    ],
  },
];

const menuPhotos = [
  {
    webp: "/media/images/bar-daytime.webp",
    webp2x: "/media/images/bar-daytime@2x.webp",
    jpg: "/media/images/bar-daytime.jpg",
    full: "/media/images/bar-daytime@2x.webp",
    width: 1024,
    height: 767,
    alt: "Lonell's Soul Food bar and dining area during the day",
  },
  {
    webp: "/media/images/bar-far-end.webp",
    webp2x: "/media/images/bar-far-end@2x.webp",
    jpg: "/media/images/bar-far-end.jpg",
    full: "/media/images/bar-far-end@2x.webp",
    width: 767,
    height: 1024,
    alt: "Counter seating with beverage dispensers and Lonell's Soul Food Cafe logo",
  },
  {
    webp: "/media/images/bar-pitchers.webp",
    webp2x: "/media/images/bar-pitchers@2x.webp",
    jpg: "/media/images/bar-pitchers.jpg",
    full: "/media/images/bar-pitchers@2x.webp",
    width: 1024,
    height: 731,
    alt: "Beverage dispensers with water, iced tea, and fruit punch at the bar",
  },
  {
    webp: "/media/images/dining-from-rear.webp",
    webp2x: "/media/images/dining-from-rear@2x.webp",
    jpg: "/media/images/dining-from-rear.jpg",
    full: "/media/images/dining-from-rear@2x.webp",
    width: 768,
    height: 1024,
    alt: "Full dining room view with bar seating and chandelier",
  },
  {
    webp: "/media/images/interior-dining.webp",
    webp2x: "/media/images/interior-dining@2x.webp",
    jpg: "/media/images/interior-dining.jpg",
    full: "/media/images/interior-dining@2x.webp",
    width: 767,
    height: 1024,
    alt: "Dining room with natural light, orchid centerpieces, and woven pendant lighting",
  },
  {
    webp: "/media/images/side-tables-dining.webp",
    webp2x: "/media/images/side-tables-dining@2x.webp",
    jpg: "/media/images/side-tables-dining.jpg",
    full: "/media/images/side-tables-dining@2x.webp",
    width: 767,
    height: 1024,
    alt: "Booth seating with leather banquette and table lamps",
  },
