---
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageLightboxGallery from "../components/ImageLightboxGallery.astro";
import Section from "../components/Section.astro";

interface MenuItem {
  name: string;
  description: string;
  price: string;
  slug?: string;
}

interface MenuCategory {
  name: string;
  subtitle: string;
  items: MenuItem[];
}

const menuCategories: MenuCategory[] = [
  {
    name: "Dinner Plates",
    subtitle: "Served with 2 Sides",
    items: [
      { name: "Baked Chicken or Fried Chicken", description: "Golden-brown, seasoned to perfection. A classic done right.", price: "$24", slug: "fried-chicken" },
      { name: "Meatloaf", description: "Homestyle meatloaf, rich and savory, served with gravy.", price: "$23", slug: "meatloaf" },
      { name: "Oxtail", description: "Slow-cooked, fall-off-the-bone tender. Our most popular dish.", price: "$32", slug: "oxtails" },
      { name: "Pork Chops", description: "Cooked to order, thick-cut and well-seasoned.", price: "$24", slug: "pork-chops" },
      { name: "Turkey Chop", description: "Cooked to order — a lean, flavorful alternative.", price: "$27", slug: "turkey-chop" },
      { name: "Catfish", description: "Crispy, Louisiana-style seasoned catfish.", price: "$26", slug: "catfish" },
      { name: "Short Ribs", description: "Rich, braised short ribs. Available Friday & Saturday only.", price: "$28", slug: "short-ribs" },
      { name: "Brisket", description: "Tender, slow-smoked brisket, sliced and sauced.", price: "$21", slug: "brisket" },
    ],
  },
  {
    name: "A La Carte Proteins",
    subtitle: "No sides included",
    items: [
      { name: "Baked Chicken or Fried Chicken", description: "", price: "$15" },
      { name: "Meatloaf", description: "", price: "$15" },
      { name: "Pork Chop", description: "Cooked to order", price: "$15" },
      { name: "Turkey Chop", description: "Cooked to order", price: "$17" },
      { name: "Catfish", description: "", price: "$17" },
      { name: "Short Ribs", description: "Fri & Sat only", price: "$20" },
      { name: "Brisket", description: "", price: "$18" },
    ],
  },
  {
    name: "Sides",
    subtitle: "$8 each",
    items: [
      { name: "String Beans", description: "Fresh green beans, Southern-style", price: "" },
      { name: "Collard Greens", description: "Slow-cooked with smoked turkey", price: "" },
      { name: "Red Beans & Rice", description: "Cajun-style with Andouille sausage", price: "" },
      { name: "Mac and Cheese", description: "Five-cheese blend, baked golden", price: "" },
      { name: "Black-Eyed Peas", description: "Hearty, seasoned, and slow-simmered", price: "" },
      { name: "Yams", description: "Candied yams, sweet and tender", price: "" },
      { name: "Mashed Potatoes", description: "Creamy, buttery mashed potatoes", price: "" },
      { name: "Gravy", description: "Rich brown gravy", price: "" },
      { name: "Hot Water Cornbread (2)", description: "Crispy, golden cornmeal cakes", price: "" },
      { name: "Cornbread (1)", description: "Classic Southern cornbread muffin", price: "" },
    ],
  },
  {
    name: "Desserts",
    subtitle: "By the slice",
    items: [
      { name: "Pound Cake", description: "Classic buttery pound cake", price: "" },
      { name: "Peach Cobbler", description: "Southern-style, warm and spiced", price: "" },
      { name: "Banana Pudding", description: "Layers of vanilla wafers, fresh bananas, and homemade custard", price: "" },
    ],
  },
  {
    name: "Beverages",
    subtitle: "",
    items: [
      { name: "Drinks", description: "Coke products", price: "$3.00" },
      { name: "Muddy Water", description: "House specialty beverage", price: "$3.75" },
      { name: "Lemonade", description: "Fresh-squeezed", price: "$3.50" },
      { name: "Bottled Water", description: "Aqua Panna", price: "$5.00" },
    ],
  },
];

const menuPhotos = [
  {
    webp: "/media/images/bar-daytime.webp",
    webp2x: "/media/images/bar-daytime@2x.webp",
    jpg: "/media/images/bar-daytime.jpg",
    full: "/media/images/bar-daytime@2x.webp",
    width: 1024,
    height: 767,
    alt: "Lonell's Soul Food bar and dining area during the day",
  },
  {
    webp: "/media/images/bar-far-end.webp",
    webp2x: "/media/images/bar-far-end@2x.webp",
    jpg: "/media/images/bar-far-end.jpg",
    full: "/media/images/bar-far-end@2x.webp",
    width: 767,
    height: 1024,
    alt: "Counter seating with beverage dispensers and Lonell's Soul Food Cafe logo",
  },
  {
    webp: "/media/images/bar-pitchers.webp",
    webp2x: "/media/images/bar-pitchers@2x.webp",
    jpg: "/media/images/bar-pitchers.jpg",
    full: "/media/images/bar-pitchers@2x.webp",
    width: 1024,
    height: 731,
    alt: "Beverage dispensers with water, iced tea, and fruit punch at the bar",
  },
  {
    webp: "/media/images/dining-from-rear.webp",
    webp2x: "/media/images/dining-from-rear@2x.webp",
    jpg: "/media/images/dining-from-rear.jpg",
    full: "/media/images/dining-from-rear@2x.webp",
    width: 768,
    height: 1024,
    alt: "Full dining room view with bar seating and chandelier",
  },
  {
    webp: "/media/images/interior-dining.webp",
    webp2x: "/media/images/interior-dining@2x.webp",
    jpg: "/media/images/interior-dining.jpg",
    full: "/media/images/interior-dining@2x.webp",
    width: 767,
    height: 1024,
    alt: "Dining room with natural light, orchid centerpieces, and woven pendant lighting",
  },
  {
    webp: "/media/images/side-tables-dining.webp",
    webp2x: "/media/images/side-tables-dining@2x.webp",
    jpg: "/media/images/side-tables-dining.jpg",
    full: "/media/images/side-tables-dining@2x.webp",
    width: 767,
    height: 1024,
    alt: "Booth seating with leather banquette and table lamps",
  },
];
---

<!-- Menu schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": "Lonell's Soul Food Cuisine Menu",
  "description": "Dinner plates served with 2 sides, a la carte proteins, sides, desserts, and beverages.",
  "hasMenuItem": [
    { "@type": "MenuItem", "name": "Oxtail Plate", "offers": { "@type": "Offer", "price": "32.00", "priceCurrency": "USD" } },
    { "@type": "MenuItem", "name": "Fried Chicken Dinner", "offers": { "@type": "Offer", "price": "24.00", "priceCurrency": "USD" } },
    { "@type": "MenuItem", "name": "Catfish", "offers": { "@type": "Offer", "price": "26.00", "priceCurrency": "USD" } },
    { "@type": "MenuItem", "name": "Short Ribs", "offers": { "@type": "Offer", "price": "28.00", "priceCurrency": "USD" } },
    { "@type": "MenuItem", "name": "Pork Chops", "offers": { "@type": "Offer", "price": "24.00", "priceCurrency": "USD" } },
    { "@type": "MenuItem", "name": "Brisket", "offers": { "@type": "Offer", "price": "21.00", "priceCurrency": "USD" } }
  ]
})}></script>

<BaseLayout title="Menu">
  <div class="min-h-screen pb-16">
    <Section eyebrow="A Place of Love" title="Our Menu" description="Authentic soul food made from scratch. Dinner plates include your choice of two sides. Dine-in, takeout, or delivery.">
      <div class="mt-12 space-y-16">
        {menuCategories.map((category) => (
          <div>
            <div class="flex items-baseline gap-3 mb-6">
              <h3 class="font-display text-2xl font-semibold text-[var(--color-accent)]">{category.name}</h3>
              {category.subtitle && (
                <span class="text-xs tracking-[0.1em] uppercase text-[var(--color-text-muted)]">{category.subtitle}</span>
              )}
            </div>
            <div class="space-y-6">
              {category.items.map((item) => (
                <div class="flex justify-between items-start gap-4 pb-6 border-b border-[var(--color-border-subtle)] last:border-0">
                  <div>
                    <h4 class="font-display text-lg font-medium">
                      {item.slug ? (
                        <a href={`/menu/${item.slug}`} class="hover:text-[var(--color-accent)] transition-colors">
                          {item.name}
                        </a>
                      ) : (
                        item.name
                      )}
                    </h4>
                    {item.description && (
                      <p class="text-sm text-[var(--color-text-secondary)] mt-1">{item.description}</p>
                    )}
                  </div>
                  {item.price && (
                    <span class="text-sm text-[var(--color-accent)] whitespace-nowrap">{item.price}</span>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Promotions -->
      <div class="mt-16 p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-brand-amber)]/20 text-center">
        <span class="eyebrow" data-reveal>Special Offer</span>
        <h3 class="font-display text-xl font-semibold mb-2" data-reveal>Senior Discount</h3>
        <p class="text-sm text-[var(--color-text-secondary)]">10% off for seniors every Sunday</p>
      </div>

      <div class="mt-16">
        <span class="eyebrow" data-reveal>Inside Lonell's</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-6" data-reveal>Where We Serve</h2>
        <ImageLightboxGallery photos={menuPhotos} mobileCarousel />
      </div>
    </Section>
  </div>
</BaseLayout>
