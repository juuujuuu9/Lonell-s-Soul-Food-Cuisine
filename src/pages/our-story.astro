---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
---

<BaseLayout title="Our Story" noindex description="Discover the story behind Lonell's Soul Food Cuisine — nearly 30 years of catering experience brought to a permanent home in South Los Angeles. Black-owned, family-operated, 'A Place of Love.'">
  <div class="min-h-screen pb-16">
    <Section eyebrow="Our Roots" title="'A Place of Love'" description="Lonell's Soul Food Cuisine is more than a restaurant. It's a gathering place built on nearly three decades of culinary craft, community pride, and the belief that food made with love tastes better." />

    <!-- Origin story -->
    <section class="section-padding bg-[var(--color-surface-card)]">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <picture class="block overflow-hidden rounded-xl border border-[var(--color-border-subtle)]">
              <source
                srcset="/media/images/dining-bar.webp 1x, /media/images/dining-bar@2x.webp 2x"
                type="image/webp"
              />
              <img
                src="/media/images/dining-bar.jpg"
                alt="Interior of Lonell's Soul Food dining room and bar"
                width="768"
                height="1024"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </picture>
          </div>
          <div class="space-y-4">
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed" data-reveal>
              Since 1995, Lonell Anderson has thrived in the catering industry — serving high-profile clients including 
              Shaquille O'Neal and Magic Johnson, and catering a diverse range of events from weddings to corporate gatherings. 
              That experience built the foundation that Lonell's Soul Food Cuisine stands on today.
            </p>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed" data-reveal>
              After nearly three decades of bringing soul food to people, Lonell evolved his vision into something permanent: 
              a restaurant where the comfort and heritage of home-cooked soul food can be enjoyed in a welcoming, dynamic setting. 
              Lonell's opened in 2024 at 8501 S Vermont Ave in South Los Angeles — and it was built to last.
            </p>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed" data-reveal>
              Every dish tells a story. From oxtails slow-cooked until fall-off-the-bone tender, to fried chicken golden and crisp, 
              to collard greens simmered with smoked turkey — each recipe blends the comforting flavors of traditional home cooking 
              with subtle, modern touches. This is food that nourishes both body and soul.
            </p>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed" data-reveal>
              <strong class="text-[var(--color-accent)]">"A Place of Love"</strong> isn't just a tagline. It's our promise. 
              Every guest is treated like family. Every meal is made from scratch. Every visit is an invitation to slow down, 
              connect, and savor something real.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Leadership -->
    <Section eyebrow="The People Behind It" title="Meet the Team">
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <h3 class="font-display text-lg font-semibold mb-1">Lonell Anderson</h3>
          <p class="text-xs text-[var(--color-accent)] uppercase tracking-widest mb-3">Founder & Owner</p>
          <p class="text-sm text-[var(--color-text-secondary)]">With nearly 30 years in the catering industry, Lonell brings deep culinary expertise, operational excellence, and a heart for community to every plate. His vision: make Los Angeles a true destination for authentic, home-cooked soul food.</p>
        </div>
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <h3 class="font-display text-lg font-semibold mb-1">Rev. Quanetha Hunt</h3>
          <p class="text-xs text-[var(--color-accent)] uppercase tracking-widest mb-3">Co-Manager</p>
          <p class="text-sm text-[var(--color-text-secondary)]">Rev. Quanetha Hunt brings a spirit of service and community to the management of Lonell's. Together with Lonell, she ensures every guest feels at home and every event reflects the warmth the restaurant was built on.</p>
        </div>
      </div>
    </Section>

    <!-- Values -->
    <section class="section-padding">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8">
          <span class="eyebrow" data-reveal>What We Stand For</span>
          <h2 class="font-display text-3xl md:text-4xl font-bold mt-2" data-reveal>Our Values</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
            <h3 class="font-display text-lg font-semibold mb-2">Proudly Black-Owned</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">Lonell's is a Black-owned business rooted in South Los Angeles. We honor the culinary traditions of the African American community and contribute to the cultural fabric of our neighborhood.</p>
          </div>
          <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
            <h3 class="font-display text-lg font-semibold mb-2">Family Recipes</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">Our menu is built on scratch-made dishes rooted in the soul food tradition. No shortcuts, no compromises — just honest cooking that celebrates the richness of African American culinary heritage.</p>
          </div>
          <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
            <h3 class="font-display text-lg font-semibold mb-2">Community First</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">Soul food represents more than a meal — it embodies tradition, community, and comfort. We partner with local organizations and artists to keep South LA thriving. Our table is your table.</p>
          </div>
          <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
            <h3 class="font-display text-lg font-semibold mb-2">Live Entertainment</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">Jazz nights, gospel brunches, karaoke Saturdays — we're one of the few soul food restaurants in LA with consistent live entertainment every week. Dinner and a show, every visit.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Location context -->
    <section class="section-padding bg-[var(--color-surface-card)]">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div class="text-center md:text-left">
            <span class="eyebrow" data-reveal>Where We Are</span>
            <h2 class="font-display text-3xl md:text-4xl font-bold mb-4" data-reveal>Vermont Knolls, South LA</h2>
            <p class="text-[var(--color-text-secondary)] leading-relaxed" data-reveal>
              Located at 8501 S Vermont Ave in the Vermont Knolls neighborhood of South Los Angeles — an area with 
              deep African American cultural heritage and a thriving community. We're proud to serve this neighborhood 
              and everyone who visits.
            </p>
            <div class="mt-8">
              <a href="/contact" class="inline-flex items-center px-8 py-3 bg-[var(--color-accent)] text-black font-semibold rounded-full hover:bg-[var(--color-accent-hover)] transition-colors">
                Find Us
              </a>
            </div>
          </div>
          <div>
            <picture class="block overflow-hidden rounded-xl border border-[var(--color-border-subtle)]">
              <source
                srcset="/media/images/street-corner.webp 1x, /media/images/street-corner@2x.webp 2x"
                type="image/webp"
              />
              <img
                src="/media/images/street-corner.jpg"
                alt="Street corner at 85th St and Vermont Ave showing Lonell's Soul Food"
                width="767"
                height="1024"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </picture>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
