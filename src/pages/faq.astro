---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

const faqs = [
  {
    q: "What type of cuisine does Lonell's serve?",
    a: "We serve authentic Southern soul food. Our menu includes oxtails (slow-cooked, fall-off-the-bone tender), fried chicken, baked chicken, meatloaf, catfish, pork chops, turkey chops, short ribs (Friday & Saturday only), brisket, and classic Southern sides like collard greens, mac and cheese, yams, black-eyed peas, red beans & rice, and string beans. Everything is made from scratch using family recipes.",
  },
  {
    q: "What are Lonell's hours of operation?",
    a: "We are open Tuesday through Sunday. Closed on Monday. Tuesday to Thursday: 11:00 AM to 7:00 PM. Friday to Saturday: 11:00 AM to 9:00 PM. Sunday: 11:00 AM to 5:00 PM.",
  },
  {
    q: "Does Lonell's have live music?",
    a: "Yes! Live entertainment is a cornerstone of what makes Lonell's special. Wednesday: Live Jazz 6-9pm. Friday: Live Jazz 6-9pm. Saturday: Karaoke 6-9pm. Sunday: Live Music during Brunch 1-5pm.",
  },
  {
    q: "When is Sunday Brunch and what's special about it?",
    a: "Sunday Brunch is served from 11:00 AM to 5:00 PM with live music from 1:00 PM to 5:00 PM. Free champagne is included with your brunch. Seniors and government workers receive a 10% discount with valid ID.",
  },
  {
    q: "Do you offer vegan or vegetarian soul food options?",
    a: "We have several vegetarian-friendly sides including collard greens, red beans & rice, mac and cheese, string beans, black-eyed peas, yams, and cornbread. Please let your server know about any dietary restrictions and we'll do our best to accommodate you.",
  },
  {
    q: "Do you take reservations?",
    a: "Yes, we accept reservations. You can call us at (323) 451-3104 or email reservations@lonells.com to book a table. Walk-ins are also always welcome.",
  },
  {
    q: "Does Lonell's offer takeout or delivery?",
    a: "Yes, we offer both takeout and delivery. Call (323) 451-3104 to place a takeout order or check your favorite delivery app.",
  },
  {
    q: "What catering services do you offer?",
    a: "We cater events of all sizes, from small family gatherings to corporate events and celebrations. Contact us at reservations@lonells.com or call (323) 451-3104 for a custom quote.",
  },
  {
    q: "Do you have private event spaces?",
    a: "Yes! We offer two private event spaces: the Dining Room and the Small Room, each with a maximum capacity of 50 guests. Perfect for birthday parties, anniversaries, corporate dinners, community events, and celebrations. Email reservations@lonells.com or call (323) 451-3104 to book.",
  },
  {
    q: "Is Lonell's family-owned and Black-owned?",
    a: "Yes, Lonell's Soul Food Cuisine is a proud Black-owned, family-owned business in South Los Angeles. 'A Place of Love' is our promise. Every guest is treated like family.",
  },
  {
    q: "What's the parking situation?",
    a: "Street parking is available and has been described by guests as 'a breeze.' There is also additional parking nearby.",
  },
  {
    q: "Is there a senior or government worker discount?",
    a: "Yes! We offer a 10% discount for seniors and government workers with valid ID every day. Just let your server know when you order.",
  },
  {
    q: "How does the SMS club work?",
    a: "Text SOUL to (323) XXX-XXXX to join our SoulFood SMS Club. You'll get exclusive offers, menu previews, and event invitations. Get promo code SOUL10 for 10% off your next order plus a free champagne brunch upgrade. Reply STOP anytime to cancel. Message & data rates may apply.",
  },
];
---

<BaseLayout title="FAQ" description="Frequently asked questions about Lonell's Soul Food Cuisine, including hours, menu, live music, reservations, private events, parking, and more in South Los Angeles.">
  <div class="min-h-screen pb-16">
    <Section eyebrow="Questions" title="Frequently Asked Questions" description="Everything you need to know before you visit Lonell's Soul Food Cuisine.">
      <div class="mt-12 space-y-0">
        {faqs.map(({ q, a }, i) => (
          <details class="group border-b border-[var(--color-border-subtle)] last:border-0">
            <summary class="flex items-center justify-between py-5 cursor-pointer list-none hover:text-[var(--color-accent)] transition-colors">
              <span class="font-display text-lg font-medium pr-4">{q}</span>
              <svg class="w-4 h-4 shrink-0 transition-transform duration-200 group-open:rotate-45 text-[var(--color-text-muted)]" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="8" y1="2" x2="8" y2="14" />
                <line x1="2" y1="8" x2="14" y2="8" />
              </svg>
            </summary>
            <div class="pb-5">
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{a}</p>
            </div>
          </details>
        ))}
      </div>
    </Section>
  </div>
</BaseLayout>
