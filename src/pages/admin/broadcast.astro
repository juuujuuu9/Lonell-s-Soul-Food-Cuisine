---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { isSmsEnabled } from "../../lib/env";
import { and, count, eq } from "drizzle-orm";

export const prerender = false;

const smsEnabled = isSmsEnabled();
let activeSubscribers = 0;
let dbError: string | null = null;

if (isDbReady()) {
  try {
    const [result] = await db!
      .select({ value: count() })
      .from(schema.subscribers)
      .where(and(eq(schema.subscribers.optOut, false)));
    activeSubscribers = result.value;
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
  }
} else {
  dbError = "DATABASE_URL is not configured.";
}
---

<BaseLayout title="Send Broadcast">
  <div class="min-h-screen pb-16">
    <div class="max-w-2xl mx-auto px-4">
      <a href="/admin" class="text-xs text-[var(--color-accent)] hover:underline">&larr; Back to Dashboard</a>
      <h1 class="font-display text-4xl font-bold mt-4 mb-2">Send Broadcast</h1>
      <p class="text-sm text-[var(--color-text-secondary)] mb-8">
        Send a one-time SMS to all {activeSubscribers} active subscriber{activeSubscribers === 1 ? "" : "s"}.
        {!smsEnabled && (
          <span class="block mt-2 text-[var(--color-brand-amber)]">
            SMS is in simulated mode — messages log to the database but are not sent via Twilio.
          </span>
        )}
      </p>

      {dbError && (
        <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
          <p class="text-sm text-red-400 font-medium">Database Error</p>
          <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
        </div>
      )}

      <form id="broadcast-form" class="space-y-6">
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <label for="message" class="block text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-3">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            maxlength="1600"
            placeholder="Lonell's Soul Food Cuisine: This Saturday — live jazz from 6pm. Walk in or call (323) 451-3104. Reply STOP to opt-out."
            class="w-full px-4 py-3 bg-[var(--color-surface-base)] border border-[var(--color-border-subtle)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent)] resize-y min-h-[140px]"
          ></textarea>
          <div class="flex items-center justify-between mt-2 text-xs text-[var(--color-text-muted)]">
            <span>Start with <strong class="text-[var(--color-text-secondary)]">Lonell's Soul Food Cuisine:</strong> and end with <strong class="text-[var(--color-text-secondary)]">Reply STOP to opt-out.</strong></span>
            <span id="char-count">0 / 1600</span>
          </div>
        </div>

        <div id="broadcast-status" class="hidden p-4 rounded-xl text-sm"></div>

        <button
          type="submit"
          id="send-btn"
          disabled={!!dbError || activeSubscribers === 0}
          class="w-full px-6 py-3 bg-[var(--color-accent)] text-black font-semibold rounded-full hover:bg-[var(--color-accent-hover)] transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Send to {activeSubscribers} subscriber{activeSubscribers === 1 ? "" : "s"}
        </button>
      </form>
    </div>
  </div>

  <script define:vars={{ smsEnabled }}>
    const form = document.getElementById("broadcast-form") as HTMLFormElement;
    const messageEl = document.getElementById("message") as HTMLTextAreaElement;
    const charCount = document.getElementById("char-count")!;
    const statusEl = document.getElementById("broadcast-status")!;
    const sendBtn = document.getElementById("send-btn") as HTMLButtonElement;

    messageEl.addEventListener("input", () => {
      charCount.textContent = `${messageEl.value.length} / 1600`;
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const message = messageEl.value.trim();
      if (!message) return;

      const count = parseInt(sendBtn.textContent?.match(/\d+/)?.[0] ?? "0", 10);
      const confirmed = confirm(
        `Send this message to ${count} subscriber${count === 1 ? "" : "s"}?\n\n${message.slice(0, 200)}${message.length > 200 ? "…" : ""}`
      );
      if (!confirmed) return;

      sendBtn.disabled = true;
      sendBtn.textContent = "Sending…";
      statusEl.className = "hidden";

      try {
        const res = await fetch("/api/admin/send-broadcast", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message }),
        });

        const data = await res.json();

        statusEl.classList.remove("hidden");
        if (res.ok) {
          statusEl.className = "p-4 rounded-xl text-sm bg-green-900/30 border border-green-500/40 text-green-300";
          statusEl.textContent = `Sent to ${data.sent} of ${data.total} subscribers.${data.simulated ? " (Simulated — check Messages log.)" : ""}`;
          messageEl.value = "";
          charCount.textContent = "0 / 1600";
        } else {
          statusEl.className = "p-4 rounded-xl text-sm bg-red-900/30 border border-red-500/40 text-red-300";
          statusEl.textContent = data.error ?? `Request failed (${res.status})`;
        }
      } catch {
        statusEl.classList.remove("hidden");
        statusEl.className = "p-4 rounded-xl text-sm bg-red-900/30 border border-red-500/40 text-red-300";
        statusEl.textContent = "Network error — are you signed in to admin?";
      } finally {
        sendBtn.disabled = false;
        sendBtn.textContent = `Send to ${count} subscriber${count === 1 ? "" : "s"}`;
      }
    });
  </script>
</BaseLayout>
