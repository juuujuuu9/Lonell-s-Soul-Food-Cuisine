---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { serverEnv } from "../../lib/env";
import { desc, sql } from "drizzle-orm";

export const prerender = false;

let reviews: Array<{
  id: number;
  platform: string | null;
  reviewerName: string | null;
  rating: number | null;
  text: string | null;
  replied: boolean | null;
  url: string | null;
  reviewedAt: Date | null;
  createdAt: Date | null;
}> = [];
let syncState: Array<{
  platform: string | null;
  rating: string | null;
  reviewCount: number | null;
  lastSyncedAt: Date | null;
  lastError: string | null;
}> = [];
let dbError: string | null = null;

const googleConfigured = !!(serverEnv("GOOGLE_PLACES_API_KEY") && serverEnv("GOOGLE_PLACE_ID"));
const yelpConfigured = !!(serverEnv("YELP_API_KEY")?.trim() && serverEnv("YELP_BUSINESS_ID")?.trim());

if (isDbReady()) {
  try {
    reviews = await db!
      .select({
        id: schema.reviews.id,
        platform: schema.reviews.platform,
        reviewerName: schema.reviews.reviewerName,
        rating: schema.reviews.rating,
        text: schema.reviews.text,
        replied: schema.reviews.replied,
        url: schema.reviews.url,
        reviewedAt: schema.reviews.reviewedAt,
        createdAt: schema.reviews.createdAt,
      })
      .from(schema.reviews)
      .orderBy(desc(sql`coalesce(${schema.reviews.reviewedAt}, ${schema.reviews.createdAt})`))
      .limit(100);

    syncState = await db!.select().from(schema.reviewSyncState);
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
    console.error("[Admin Reviews] DB error:", e);
  }
} else {
  dbError = "DATABASE_URL is not configured. Add it to your .env.local file.";
}

function syncRow(platform: string) {
  return syncState.find((s) => s.platform === platform);
}
---

<AdminLayout title="Reviews">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="font-display text-4xl font-bold mb-2">Reputation & Reviews</h1>
      <p class="text-sm text-[var(--color-text-secondary)]">
        Google Legacy API returns up to 5 reviews (API limit). Yelp returns up to 3 excerpts on Enhanced/Premium plans.
      </p>
    </div>
    <button
      type="button"
      id="sync-reviews-btn"
      disabled={!!dbError || !googleConfigured}
      class="shrink-0 px-5 py-2.5 bg-[var(--color-accent)] text-black text-sm font-semibold rounded-full hover:bg-[var(--color-accent-hover)] transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
    >
      Sync now
    </button>
  </div>

  {dbError && (
    <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
      <p class="text-sm text-red-400 font-medium">Database Error</p>
      <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
    </div>
  )}

  {!googleConfigured && (
    <div class="mb-8 p-4 bg-amber-900/20 border border-amber-500/40 rounded-xl">
      <p class="text-sm text-amber-300">Set <code class="text-amber-100">GOOGLE_PLACES_API_KEY</code> and <code class="text-amber-100">GOOGLE_PLACE_ID</code> to enable sync.</p>
    </div>
  )}

  <div id="sync-status" class="hidden mb-8 p-4 rounded-xl text-sm"></div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    {(["google", "yelp"] as const).map((platform) => {
      const row = syncRow(platform);
      const configured = platform === "google" ? googleConfigured : yelpConfigured;
      return (
        <div class="p-5 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-1">{platform}</p>
          {row?.rating ? (
            <p class="font-display text-2xl font-bold text-[var(--color-accent)]">
              {row.rating} <span class="text-sm font-normal text-[var(--color-text-muted)]">/ 5</span>
            </p>
          ) : (
            <p class="font-display text-2xl font-bold text-[var(--color-text-muted)]">—</p>
          )}
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">
            {row?.reviewCount != null ? `${row.reviewCount} total on platform` : configured ? "Not synced yet" : "API not configured"}
          </p>
          <p class="text-xs text-[var(--color-text-muted)] mt-2">
            {row?.lastSyncedAt
              ? `Last sync ${row.lastSyncedAt.toLocaleString()}`
              : "Never synced"}
          </p>
          {row?.lastError && (
            <p class="text-xs text-[var(--color-rose)] mt-1">{row.lastError}</p>
          )}
        </div>
      );
    })}
  </div>

  <div class="mb-8 p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
    <h2 class="font-display text-lg font-semibold mb-3">Review Reply Templates</h2>
    <p class="text-sm text-[var(--color-text-secondary)] mb-4">Use these templates when responding to reviews on Google, Yelp, or Facebook.</p>
    <div class="space-y-4">
      <div class="p-4 bg-[var(--color-surface-base)] rounded-lg">
        <p class="text-xs text-[var(--color-neon)] mb-2">5-Star Response</p>
        <p class="text-sm text-[var(--color-text-secondary)]">"Thank you so much for the kind words, {'{name}'}! We're thrilled you enjoyed your experience at Lonell's. Hope to see you again soon. Bring a friend next time!"</p>
      </div>
      <div class="p-4 bg-[var(--color-surface-base)] rounded-lg">
        <p class="text-xs text-[var(--color-accent)] mb-2">4-Star / Positive Feedback</p>
        <p class="text-sm text-[var(--color-text-secondary)]">"Thanks for the feedback, {'{name}'}! We appreciate your support and will share your comments with our team. Can't wait to have you back!"</p>
      </div>
      <div class="p-4 bg-[var(--color-surface-base)] rounded-lg">
        <p class="text-xs text-[var(--color-rose)] mb-2">3-Star / Constructive</p>
        <p class="text-sm text-[var(--color-text-secondary)]">"Hi {'{name}'}, thank you for your honest feedback. We're sorry your visit didn't fully meet expectations. We'd love the chance to make it right. Please reach out to us at (323) 451-3104."</p>
      </div>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-[var(--color-border-subtle)] text-xs tracking-wider uppercase text-[var(--color-text-muted)]">
          <th class="text-left py-3 pr-4">Platform</th>
          <th class="text-left py-3 pr-4">Reviewer</th>
          <th class="text-left py-3 pr-4">Rating</th>
          <th class="text-left py-3 pr-4">Snippet</th>
          <th class="text-left py-3 pr-4">Replied</th>
          <th class="text-left py-3 pr-4">Date</th>
        </tr>
      </thead>
      <tbody>
        {reviews.length === 0 && (
          <tr><td colspan="6" class="py-8 text-center text-[var(--color-text-muted)]">No synced reviews yet. Click Sync now to pull from Google.</td></tr>
        )}
        {reviews.map((rev) => (
          <tr class="border-b border-[var(--color-border-subtle)] hover:bg-[var(--color-surface-hover)]">
            <td class="py-3 pr-4 text-xs capitalize">{rev.platform}</td>
            <td class="py-3 pr-4">
              {rev.url ? (
                <a href={rev.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">
                  {rev.reviewerName || "Anonymous"}
                </a>
              ) : (
                rev.reviewerName || "Anonymous"
              )}
            </td>
            <td class="py-3 pr-4">
              <span class="text-[var(--color-accent)]">{"★".repeat(rev.rating ?? 0)}{"☆".repeat(5 - (rev.rating ?? 0))}</span>
            </td>
            <td class="py-3 pr-4 max-w-xs truncate text-[var(--color-text-secondary)]">{rev.text}</td>
            <td class="py-3 pr-4">
              <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${rev.replied ? "bg-green-900/30 text-green-400" : "bg-amber-900/30 text-amber-400"}`}>
                {rev.replied ? "Replied" : "Pending"}
              </span>
            </td>
            <td class="py-3 pr-4 text-[var(--color-text-muted)] text-xs">
              {(rev.reviewedAt ?? rev.createdAt)?.toLocaleDateString()}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script>
    const btn = document.getElementById("sync-reviews-btn") as HTMLButtonElement | null;
    const statusEl = document.getElementById("sync-status");

    btn?.addEventListener("click", async () => {
      if (!btn || !statusEl) return;
      btn.disabled = true;
      btn.textContent = "Syncing…";
      statusEl.className = "hidden";

      try {
        const res = await fetch("/api/admin/sync-reviews", {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: "{}",
        });

        const text = await res.text();
        let data = {};
        try {
          data = text ? JSON.parse(text) : {};
        } catch {
          throw new Error(`${res.status} ${res.statusText}: ${text.slice(0, 120)}`);
        }

        statusEl.classList.remove("hidden");
        if (res.ok) {
          const g = data.google;
          const y = data.yelp;
          statusEl.className = "mb-8 p-4 rounded-xl text-sm bg-green-900/30 border border-green-500/40 text-green-300";
          statusEl.textContent = `Google: ${g?.upserted ?? 0} review(s) synced${g?.rating != null ? `, ${g.rating}★ (${g.reviewCount} total)` : ""}.${y?.skipped ? ` Yelp skipped (${y.skipped}).` : y?.upserted ? ` Yelp: ${y.upserted} synced.` : ""}`;
          setTimeout(() => location.reload(), 1200);
        } else {
          const g = data.google;
          statusEl.className = "mb-8 p-4 rounded-xl text-sm bg-red-900/30 border border-red-500/40 text-red-300";
          statusEl.textContent = String(g?.error ?? data.error ?? `Sync failed (${res.status})`);
        }
      } catch (err) {
        statusEl.classList.remove("hidden");
        statusEl.className = "mb-8 p-4 rounded-xl text-sm bg-red-900/30 border border-red-500/40 text-red-300";
        statusEl.textContent = err instanceof Error ? err.message : "Request failed";
      } finally {
        btn.disabled = false;
        btn.textContent = "Sync now";
      }
    });
  </script>
</AdminLayout>
