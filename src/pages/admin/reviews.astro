---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { desc } from "drizzle-orm";

export const prerender = false;

let reviews: Array<{ id: number; platform: string | null; reviewerName: string | null; rating: number | null; text: string | null; replied: boolean | null; url: string | null; createdAt: Date | null }> = [];
let dbError: string | null = null;

if (isDbReady()) {
  try {
    reviews = await db!
      .select({
        id: schema.reviews.id,
        platform: schema.reviews.platform,
        reviewerName: schema.reviews.reviewerName,
        rating: schema.reviews.rating,
        text: schema.reviews.text,
        replied: schema.reviews.replied,
        url: schema.reviews.url,
        createdAt: schema.reviews.createdAt,
      })
      .from(schema.reviews)
      .orderBy(desc(schema.reviews.createdAt))
      .limit(100);
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
    console.error("[Admin Reviews] DB error:", e);
  }
} else {
  dbError = "DATABASE_URL is not configured. Add it to your .env.local file.";
}
---

<AdminLayout title="Reviews">
  <h1 class="font-display text-4xl font-bold mb-8">Reputation & Reviews</h1>

      {dbError && (
        <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
          <p class="text-sm text-red-400 font-medium">Database Error</p>
          <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
        </div>
      )}

      <div class="mb-8 p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
        <h2 class="font-display text-lg font-semibold mb-3">Review Reply Templates</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mb-4">Use these templates when responding to reviews on Google, Yelp, or Facebook.</p>
        <div class="space-y-4">
          <div class="p-4 bg-[var(--color-surface-base)] rounded-lg">
            <p class="text-xs text-[var(--color-neon)] mb-2">5-Star Response</p>
            <p class="text-sm text-[var(--color-text-secondary)]">"Thank you so much for the kind words, {'{name}'}! We're thrilled you enjoyed your experience at Lonell's. Hope to see you again soon. Bring a friend next time!"</p>
          </div>
          <div class="p-4 bg-[var(--color-surface-base)] rounded-lg">
            <p class="text-xs text-[var(--color-accent)] mb-2">4-Star / Positive Feedback</p>
            <p class="text-sm text-[var(--color-text-secondary)]">"Thanks for the feedback, {'{name}'}! We appreciate your support and will share your comments with our team. Can't wait to have you back!"</p>
          </div>
          <div class="p-4 bg-[var(--color-surface-base)] rounded-lg">
            <p class="text-xs text-[var(--color-rose)] mb-2">3-Star / Constructive</p>
            <p class="text-sm text-[var(--color-text-secondary)]">"Hi {'{name}'}, thank you for your honest feedback. We're sorry your visit didn't fully meet expectations. We'd love the chance to make it right. Please reach out to us at (323) 451-3104."</p>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border-subtle)] text-xs tracking-wider uppercase text-[var(--color-text-muted)]">
              <th class="text-left py-3 pr-4">Platform</th>
              <th class="text-left py-3 pr-4">Reviewer</th>
              <th class="text-left py-3 pr-4">Rating</th>
              <th class="text-left py-3 pr-4">Snippet</th>
              <th class="text-left py-3 pr-4">Replied</th>
              <th class="text-left py-3 pr-4">Date</th>
            </tr>
          </thead>
          <tbody>
            {reviews.length === 0 && (
              <tr><td colspan="6" class="py-8 text-center text-[var(--color-text-muted)]">No reviews tracked yet. Reviews are added via the API or admin panel.</td></tr>
            )}
            {reviews.map((rev) => (
              <tr class="border-b border-[var(--color-border-subtle)] hover:bg-[var(--color-surface-hover)]">
                <td class="py-3 pr-4 text-xs">{rev.platform}</td>
                <td class="py-3 pr-4">{rev.reviewerName || 'Anonymous'}</td>
                <td class="py-3 pr-4">
                  <span class="text-[var(--color-accent)]">{'★'.repeat(rev.rating ?? 0)}{'☆'.repeat(5 - (rev.rating ?? 0))}</span>
                </td>
                <td class="py-3 pr-4 max-w-xs truncate text-[var(--color-text-secondary)]">{rev.text}</td>
                <td class="py-3 pr-4">
                  <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${rev.replied ? 'bg-green-900/30 text-green-400' : 'bg-amber-900/30 text-amber-400'}`}>
                    {rev.replied ? 'Replied' : 'Pending'}
                  </span>
                </td>
                <td class="py-3 pr-4 text-[var(--color-text-muted)] text-xs">{rev.createdAt?.toLocaleDateString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
</AdminLayout>
