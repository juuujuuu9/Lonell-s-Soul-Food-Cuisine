---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { desc } from "drizzle-orm";

export const prerender = false;

let messages: Array<{ id: number; toNumber: string | null; fromNumber: string | null; body: string | null; direction: string | null; status: string | null; simulated: boolean | null; createdAt: Date | null }> = [];
let dbError: string | null = null;

if (isDbReady()) {
  try {
    messages = await db!
      .select({
        id: schema.messages.id,
        toNumber: schema.messages.toNumber,
        fromNumber: schema.messages.fromNumber,
        body: schema.messages.body,
        direction: schema.messages.direction,
        status: schema.messages.status,
        simulated: schema.messages.simulated,
        createdAt: schema.messages.createdAt,
      })
      .from(schema.messages)
      .orderBy(desc(schema.messages.createdAt))
      .limit(100);
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
    console.error("[Admin Messages] DB error:", e);
  }
} else {
  dbError = "DATABASE_URL is not configured. Add it to your .env.local file.";
}
---

<AdminLayout title="Messages">
  <h1 class="font-display text-4xl font-bold mb-8">SMS Messages</h1>

      {dbError && (
        <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
          <p class="text-sm text-red-400 font-medium">Database Error</p>
          <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
        </div>
      )}

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border-subtle)] text-xs tracking-wider uppercase text-[var(--color-text-muted)]">
              <th class="text-left py-3 pr-4">ID</th>
              <th class="text-left py-3 pr-4">Direction</th>
              <th class="text-left py-3 pr-4">To</th>
              <th class="text-left py-3 pr-4">From</th>
              <th class="text-left py-3 pr-4">Body</th>
              <th class="text-left py-3 pr-4">Status</th>
              <th class="text-left py-3 pr-4">Sent</th>
            </tr>
          </thead>
          <tbody>
            {messages.length === 0 && (
              <tr><td colspan="7" class="py-8 text-center text-[var(--color-text-muted)]">No messages yet.</td></tr>
            )}
            {messages.map((msg) => (
              <tr class="border-b border-[var(--color-border-subtle)] hover:bg-[var(--color-surface-hover)]">
                <td class="py-3 pr-4 text-xs">{msg.id}</td>
                <td class="py-3 pr-4">
                  <span class={`text-xs ${msg.direction === 'outbound' ? 'text-[var(--color-accent)]' : 'text-[var(--color-neon)]'}`}>
                    {msg.direction}
                  </span>
                </td>
                <td class="py-3 pr-4 text-xs">{msg.toNumber}</td>
                <td class="py-3 pr-4 text-xs">{msg.fromNumber}</td>
                <td class="py-3 pr-4 max-w-xs truncate text-[var(--color-text-secondary)]">{msg.body}</td>
                <td class="py-3 pr-4">
                  <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${msg.simulated ? 'bg-amber-900/30 text-amber-400' : 'bg-green-900/30 text-green-400'}`}>
                    {msg.simulated ? 'Simulated' : msg.status}
                  </span>
                </td>
                <td class="py-3 pr-4 text-[var(--color-text-muted)] text-xs">{msg.createdAt?.toLocaleString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
</AdminLayout>
