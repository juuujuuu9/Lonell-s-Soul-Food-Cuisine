---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isSmsEnabled, serverEnv } from "../../lib/env";

export const prerender = false;

const smsEnabled = isSmsEnabled();
---

<AdminLayout title="Settings" maxWidth="4xl">
  <h1 class="font-display text-4xl font-bold mb-8">Settings</h1>

      <!-- Environment Status -->
      <div class="space-y-6">
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <h2 class="font-display text-lg font-semibold mb-4">Environment Variables</h2>
          <p class="text-sm text-[var(--color-text-secondary)] mb-4">
            SMS runtime status:{" "}
            <strong class={smsEnabled ? "text-[var(--color-neon)]" : "text-[var(--color-brand-amber)]"}>
              {smsEnabled ? "ENABLED" : "SIMULATED"}
            </strong>
            {serverEnv("SMS_ENABLED") && (
              <span class="text-[var(--color-text-muted)]"> (SMS_ENABLED={serverEnv("SMS_ENABLED")})</span>
            )}
          </p>
          <div class="space-y-3">
            {[
              { key: "DATABASE_URL", label: "Database", sensitive: true },
              { key: "SMS_ENABLED", label: "SMS Service" },
              { key: "CRON_SECRET", label: "Cron Secret", sensitive: true },
              { key: "TWILIO_ACCOUNT_SID", label: "Twilio Account", sensitive: true },
              { key: "TWILIO_FROM_NUMBER", label: "Twilio From Number" },
              { key: "CLERK_PUBLISHABLE_KEY", label: "Clerk Publishable Key", sensitive: true },
              { key: "GOOGLE_PLACES_API_KEY", label: "Google Places API Key", sensitive: true },
              { key: "GOOGLE_PLACE_ID", label: "Google Place ID" },
              { key: "YELP_API_KEY", label: "Yelp API Key", sensitive: true },
              { key: "YELP_BUSINESS_ID", label: "Yelp Business ID" },
            ].map(({ key, label, sensitive }) => (
              <div class="flex items-center justify-between py-2 border-b border-[var(--color-border-subtle)] last:border-0">
                <span class="text-sm text-[var(--color-text-secondary)]">{label}</span>
                <span class="text-xs">
                  {serverEnv(key)
                    ? sensitive
                      ? `${serverEnv(key)!.slice(0, 8)}...`
                      : serverEnv(key)
                    : <span class="text-[var(--color-rose)]">Not Set</span>
                  }
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Follow-up Tasks -->
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <h2 class="font-display text-lg font-semibold mb-4">Follow-Up Tasks</h2>
          <ul class="space-y-3 text-sm text-[var(--color-text-secondary)]">
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0" />
              <span><strong class="text-white">Google Business Profile</strong>. Claim and verify the GBP listing for accurate NAP and hours.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0" />
              <span><strong class="text-white">Citation NAP Audit</strong>. Ensure NAP consistency across Yelp, TripAdvisor, and other directories.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-1.5 shrink-0" />
              <span><strong class="text-white">Professional Photography</strong>. Capture 30+ images of interior, exterior, and signature dishes.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 shrink-0 flex items-center justify-center w-4 h-4 rounded-full bg-emerald-500 text-white text-xs font-bold">✓</span>
              <span class="line-through text-[var(--color-text-muted)]"><strong class="text-emerald-400">Twilio Number</strong>. Purchased +1 (424) 295-8020. Set SMS_ENABLED=true in production.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 shrink-0 flex items-center justify-center w-4 h-4 rounded-full bg-emerald-500 text-white text-xs font-bold">✓</span>
              <span class="line-through text-[var(--color-text-muted)]"><strong class="text-emerald-400">Custom Domain</strong>. Configure domain and deploy to Vercel production.</span>
            </li>
          </ul>
        </div>
      </div>
</AdminLayout>
