---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { desc } from "drizzle-orm";

export const prerender = false;

let subscribers: Array<{ id: number; phoneNumber: string | null; keyword: string | null; optOut: boolean | null; createdAt: Date | null; promoCode: string | null; promoRedeemed: boolean | null }> = [];
let dbError: string | null = null;

if (isDbReady()) {
  try {
    subscribers = await db!
      .select({
        id: schema.subscribers.id,
        phoneNumber: schema.subscribers.phoneNumber,
        keyword: schema.subscribers.keyword,
        optOut: schema.subscribers.optOut,
        createdAt: schema.subscribers.createdAt,
        promoCode: schema.subscribers.promoCode,
        promoRedeemed: schema.subscribers.promoRedeemed,
      })
      .from(schema.subscribers)
      .orderBy(desc(schema.subscribers.createdAt))
      .limit(100);
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
    console.error("[Admin Subscribers] DB error:", e);
  }
} else {
  dbError = "DATABASE_URL is not configured. Add it to your .env.local file.";
}
---

<BaseLayout title="Subscribers">
  <div class="min-h-screen pb-16">
    <div class="max-w-6xl mx-auto px-4">
      <a href="/admin" class="text-xs text-[var(--color-accent)] hover:underline">&larr; Back to Dashboard</a>
      <h1 class="font-display text-4xl font-bold mt-4 mb-8">SMS Subscribers</h1>

      {dbError && (
        <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
          <p class="text-sm text-red-400 font-medium">Database Error</p>
          <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
        </div>
      )}

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border-subtle)] text-xs tracking-wider uppercase text-[var(--color-text-muted)]">
              <th class="text-left py-3 pr-4">ID</th>
              <th class="text-left py-3 pr-4">Phone</th>
              <th class="text-left py-3 pr-4">Keyword</th>
              <th class="text-left py-3 pr-4">Status</th>
              <th class="text-left py-3 pr-4">Promo</th>
              <th class="text-left py-3 pr-4">Signed Up</th>
            </tr>
          </thead>
          <tbody>
            {subscribers.length === 0 && (
              <tr><td colspan="6" class="py-8 text-center text-[var(--color-text-muted)]">No subscribers yet. Database may not be provisioned.</td></tr>
            )}
            {subscribers.map((sub) => (
              <tr class="border-b border-[var(--color-border-subtle)] hover:bg-[var(--color-surface-hover)]">
                <td class="py-3 pr-4 text-xs">{sub.id}</td>
                <td class="py-3 pr-4">{sub.phoneNumber}</td>
                <td class="py-3 pr-4 text-xs text-[var(--color-accent)]">{sub.keyword}</td>
                <td class="py-3 pr-4">
                  <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${sub.optOut ? 'bg-red-900/30 text-red-400' : 'bg-green-900/30 text-green-400'}`}>
                    {sub.optOut ? 'Opted Out' : 'Active'}
                  </span>
                </td>
                <td class="py-3 pr-4">
                  <span class="text-xs">{sub.promoCode || '-'}</span>
                  {sub.promoRedeemed && <span class="ml-2 text-xs text-[var(--color-neon)]">Redeemed</span>}
                </td>
                <td class="py-3 pr-4 text-[var(--color-text-muted)] text-xs">{sub.createdAt?.toLocaleDateString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>
