---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { isSmsEnabled } from "../../lib/env";
import { count } from "drizzle-orm";

export const prerender = false;

const smsEnabled = isSmsEnabled();

let subscriberCount = 0;
let messageCount = 0;
let reviewCount = 0;
let dbError: string | null = null;

if (isDbReady()) {
  try {
    const [subResult] = await db!.select({ value: count() }).from(schema.subscribers);
    subscriberCount = subResult.value;

    const [msgResult] = await db!.select({ value: count() }).from(schema.messages);
    messageCount = msgResult.value;

    const [revResult] = await db!.select({ value: count() }).from(schema.reviews);
    reviewCount = revResult.value;
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
    console.error("[Admin Dashboard] DB error:", e);
  }
} else {
  dbError = "DATABASE_URL is not configured. Add it to your .env.local file.";
}
---

<AdminLayout title="Admin Dashboard">
  {dbError && (
    <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
      <p class="text-sm text-red-400 font-medium">Database Connection Error</p>
      <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
    </div>
  )}

  <span class="eyebrow">Dashboard</span>
  <h1 class="font-display text-4xl md:text-5xl font-bold mb-2">Admin Panel</h1>
  <p class="text-[var(--color-text-secondary)] mb-12">Manage subscribers, messages, and reputation.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
    <a href="/admin/subscribers" class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)] transition-colors">
      <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-2">Subscribers</p>
      <p class="font-display text-4xl font-bold text-[var(--color-accent)]">{subscriberCount}</p>
    </a>
    <a href="/admin/messages" class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-neon)] transition-colors">
      <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-2">Messages</p>
      <p class="font-display text-4xl font-bold text-[var(--color-neon)]">{messageCount}</p>
    </a>
    <a href="/admin/reviews" class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)] hover:border-[var(--color-rose)] transition-colors">
      <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-2">Reviews</p>
      <p class="font-display text-4xl font-bold text-[var(--color-rose)]">{reviewCount}</p>
    </a>
  </div>

  <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="font-display text-xl font-semibold">SMS Service</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mt-1">
          SMS is currently <strong class={smsEnabled ? "text-[var(--color-neon)]" : "text-[var(--color-brand-amber)]"}>{smsEnabled ? "ENABLED" : "SIMULATED"}</strong>.
          {!smsEnabled && " Messages are being logged to the database without sending."}
        </p>
      </div>
      <span class={`inline-block w-3 h-3 rounded-full ${smsEnabled ? "bg-[var(--color-neon)]" : "bg-[var(--color-accent)]"}`} />
    </div>
  </div>
</AdminLayout>
