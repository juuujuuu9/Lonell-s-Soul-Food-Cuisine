---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db, schema, isDbReady } from "../../db/index";
import { count } from "drizzle-orm";

export const prerender = false;

// Fetch dashboard stats
let subscriberCount = 0;
let messageCount = 0;
let reviewCount = 0;
let dbError: string | null = null;

if (isDbReady()) {
  try {
    const [subResult] = await db!.select({ value: count() }).from(schema.subscribers);
    subscriberCount = subResult.value;

    const [msgResult] = await db!.select({ value: count() }).from(schema.messages);
    messageCount = msgResult.value;

    const [revResult] = await db!.select({ value: count() }).from(schema.reviews);
    reviewCount = revResult.value;
  } catch (e) {
    dbError = e instanceof Error ? e.message : "Unknown database error";
    console.error("[Admin Dashboard] DB error:", e);
  }
} else {
  dbError = "DATABASE_URL is not configured. Add it to your .env.local file.";
}
---

<BaseLayout title="Admin Dashboard">
  <div class="min-h-screen pb-16">
    <div class="max-w-6xl mx-auto px-4">
      {dbError && (
        <div class="mb-8 p-4 bg-red-900/30 border border-red-500/40 rounded-xl">
          <p class="text-sm text-red-400 font-medium">Database Connection Error</p>
          <p class="text-xs text-red-300/80 mt-1">{dbError}</p>
        </div>
      )}

      <span class="eyebrow">Dashboard</span>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-2">Admin Panel</h1>
      <p class="text-[var(--color-text-secondary)] mb-12">Manage subscribers, messages, and reputation.</p>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-2">Subscribers</p>
          <p class="font-display text-4xl font-bold text-[var(--color-accent)]">{subscriberCount}</p>
        </div>
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-2">Messages</p>
          <p class="font-display text-4xl font-bold text-[var(--color-neon)]">{messageCount}</p>
        </div>
        <div class="p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
          <p class="text-xs tracking-wider uppercase text-[var(--color-text-muted)] mb-2">Reviews</p>
          <p class="font-display text-4xl font-bold text-[var(--color-rose)]">{reviewCount}</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/admin/subscribers" class="p-4 bg-[var(--color-surface-card)] rounded-lg border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)] transition-colors">
          <span class="text-xs text-[var(--color-accent)]">Manage</span>
          <p class="font-medium mt-1">Subscribers</p>
        </a>
        <a href="/admin/messages" class="p-4 bg-[var(--color-surface-card)] rounded-lg border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)] transition-colors">
          <span class="text-xs text-[var(--color-accent)]">View</span>
          <p class="font-medium mt-1">Messages</p>
        </a>
        <a href="/admin/broadcast" class="p-4 bg-[var(--color-surface-card)] rounded-lg border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)] transition-colors">
          <span class="text-xs text-[var(--color-neon)]">Send</span>
          <p class="font-medium mt-1">Broadcast</p>
        </a>
        <a href="/admin/reviews" class="p-4 bg-[var(--color-surface-card)] rounded-lg border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)] transition-colors">
          <span class="text-xs text-[var(--color-accent)]">Track</span>
          <p class="font-medium mt-1">Reviews</p>
        </a>
        <a href="/admin/settings" class="p-4 bg-[var(--color-surface-card)] rounded-lg border border-[var(--color-border-subtle)] hover:border-[var(--color-accent)] transition-colors">
          <span class="text-xs text-[var(--color-accent)]">Configure</span>
          <p class="font-medium mt-1">Settings</p>
        </a>
      </div>

      <!-- SMS Status -->
      <div class="mt-12 p-6 bg-[var(--color-surface-card)] rounded-xl border border-[var(--color-border-subtle)]">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-display text-xl font-semibold">SMS Service</h2>
            <p class="text-sm text-[var(--color-text-secondary)] mt-1">
              SMS is currently <strong class={import.meta.env.SMS_ENABLED === 'true' ? 'text-[var(--color-neon)]' : 'text-[var(--color-brand-amber)]'}>{import.meta.env.SMS_ENABLED === 'true' ? 'ENABLED' : 'SIMULATED'}</strong>.
              {import.meta.env.SMS_ENABLED !== 'true' && ' Messages are being logged to the database without sending.'}
            </p>
          </div>
          <span class={`inline-block w-3 h-3 rounded-full ${import.meta.env.SMS_ENABLED === 'true' ? 'bg-[var(--color-neon)]' : 'bg-[var(--color-accent)]'}`} />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
