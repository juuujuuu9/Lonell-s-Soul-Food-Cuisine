---
import "../styles/global.css";
import NavOverlay from "../components/NavOverlay.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Authentic Southern soul food in the heart of Los Angeles. Catering, events, and that homemade taste since day one.", ogImage = "/og-default.jpg" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Lonell's Soul Food</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Lonell's Soul Food`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      name: "Lonell's Soul Food",
      description: "Authentic Southern soul food restaurant in Los Angeles.",
      servesCuisine: "Soul Food",
      telephone: "(323) 451-3104",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Los Angeles",
        addressRegion: "CA",
        addressCountry: "US"
      },
      url: "https://lonellssoulfood.com",
      priceRange: "$$"
    })}></script>
  </head>
  <body class="min-h-screen bg-[var(--color-surface-base)] text-[var(--color-text-primary)]">
    <!-- Navigation Overlay -->
    <NavOverlay />

    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-black focus:rounded focus:font-semibold">
      Skip to main content
    </a>

    <!-- Hamburger Button -->
    <button id="menu-toggle" class="fixed top-6 right-6 z-[110] flex items-center gap-2 px-4 py-2 text-sm font-medium font-mono tracking-widest uppercase text-[var(--color-text-primary)] bg-[var(--color-surface-card)]/80 backdrop-blur-sm border border-[var(--color-border-subtle)] rounded-full hover:bg-[var(--color-surface-hover)] transition-colors" aria-label="Toggle navigation menu" aria-expanded="false">
      <span id="menu-label">MENU</span>
      <svg id="menu-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="2" y1="4" x2="14" y2="4" />
        <line x1="2" y1="8" x2="14" y2="8" />
        <line x1="2" y1="12" x2="14" y2="12" />
      </svg>
    </button>

    <main id="main-content">
      <slot />
    </main>

    <SiteFooter />
  </body>
</html>

<script>
  const toggle = document.getElementById("menu-toggle");
  const overlay = document.querySelector(".nav-overlay");
  const label = document.getElementById("menu-label");
  const icon = document.getElementById("menu-icon");

  if (toggle && overlay) {
    toggle.addEventListener("click", () => {
      const isOpen = overlay.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(isOpen));
      label.textContent = isOpen ? "CLOSE" : "MENU";
      icon.innerHTML = isOpen
        ? '<line x1="3" y1="3" x2="13" y2="13" /><line x1="13" y1="3" x2="3" y2="13" />'
        : '<line x1="2" y1="4" x2="14" y2="4" /><line x1="2" y1="8" x2="14" y2="8" /><line x1="2" y1="12" x2="14" y2="12" />';
    });

    overlay.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        overlay.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
        label.textContent = "MENU";
        icon.innerHTML = '<line x1="2" y1="4" x2="14" y2="4" /><line x1="2" y1="8" x2="14" y2="8" /><line x1="2" y1="12" x2="14" y2="12" />';
      });
    });
  }
</script>
