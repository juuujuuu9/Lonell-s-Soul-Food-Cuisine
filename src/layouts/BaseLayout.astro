---
import "../styles/global.css";
import NavOverlay from "../components/NavOverlay.astro";
import PageHeader, { type PageHeaderBackground } from "../components/PageHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import StickyHeader from "../components/StickyHeader.astro";
import TopMenuBar from "../components/TopMenuBar.astro";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  headerBackground?: PageHeaderBackground;
  headerBackgrounds?: PageHeaderBackground[];
}

const siteName = "Lonell's Soul Food Cuisine";
const defaultDescription = "Authentic soul food with live jazz, karaoke & Sunday brunch in South Los Angeles. Oxtails, fried chicken, private events. 'A Place of Love.' (323) 451-3104";
const defaultOgImage = "/og-default.jpg";
const siteUrl = "https://lonellssoulfood.com";

const { title, description = defaultDescription, ogImage = defaultOgImage, noindex = false, headerBackground, headerBackgrounds } = Astro.props;
const pageTitle = title === "Home" ? `${siteName} | Authentic Soul Food & Live Jazz in South LA` : `${title} | ${siteName}`;
const isHome = Astro.url.pathname === "/";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{pageTitle}</title>

    <!-- Favicons & PWA -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Robots -->
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Arbutus+Slab&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Hero image preload -->
    <link rel="preload" href="/media/images/wide-bar-lg.webp" as="image" type="image/webp" fetchpriority="high" />
    {isHome ? (
      <link rel="preload" href="/media/images/lonells-logo.webp" as="image" type="image/webp" fetchpriority="high" />
    ) : (
      <>
        {headerBackground && !headerBackgrounds?.length ? (
          <link rel="preload" href={headerBackground.webp} as="image" type="image/webp" fetchpriority="high" />
        ) : null}
        <link rel="preload" href="/media/images/lonells-gold-logo.webp" as="image" type="image/webp" fetchpriority="high" />
      </>
    )}

    <!-- Schema.org: LocalBusiness + Restaurant -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Restaurant", "FoodEstablishment"],
      "name": "Lonell's Soul Food Cuisine",
      "alternateName": "Lonell's Soul Food Cuisine",
      "description": "Authentic soul food restaurant with live jazz, gospel brunches, karaoke, and private event space in South Los Angeles. Founded in 2024 by Lonell Anderson after nearly 30 years in catering.",
      "foundingDate": "2024",
      "founder": {
        "@type": "Person",
        "name": "Lonell Anderson"
      },
      "employee": {
        "@type": "Person",
        "name": "Quanetha Hunt",
        "jobTitle": "Co-Manager"
      },
      "servesCuisine": "Soul Food",
      "image": `${siteUrl}/media/images/lonells-logo.jpg`,
      "telephone": "(323) 451-3104",
      "email": "reservations@lonellssoulfood.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "8501 S Vermont Ave",
        "addressLocality": "Los Angeles",
        "addressRegion": "CA",
        "postalCode": "90044",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 33.9612,
        "longitude": -118.2917
      },
      "url": siteUrl,
      "priceRange": "$$",
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "11:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "11:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "11:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "11:00", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "11:00", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "11:00", "closes": "17:00" }
      ],
      "hasMenu": `${siteUrl}/menu`,
      "acceptsReservations": "true",
      "paymentAccepted": ["Cash", "Credit Card"],
      "currenciesAccepted": "USD",
      "areaServed": "South Los Angeles"
    })}></script>

    <!-- FAQ Schema (expanded, 13 Qs for AI search readiness) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What type of cuisine does Lonell's serve?",
          "acceptedAnswer": { "@type": "Answer", "text": "We serve authentic Southern soul food including oxtails (slow-cooked, fall-off-the-bone tender), fried chicken, baked chicken, meatloaf, catfish, pork chops, turkey chops, short ribs (Friday & Saturday only), brisket, and classic Southern sides like collard greens, mac and cheese, yams, black-eyed peas, red beans & rice, and string beans. Everything is made from scratch using family recipes." }
        },
        {
          "@type": "Question",
          "name": "What are Lonell's hours of operation?",
          "acceptedAnswer": { "@type": "Answer", "text": "We are open Tuesday through Sunday. Closed on Monday. Tuesday to Thursday: 11:00 AM to 7:00 PM. Friday to Saturday: 11:00 AM to 9:00 PM. Sunday: 11:00 AM to 5:00 PM." }
        },
        {
          "@type": "Question",
          "name": "Does Lonell's have live music?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes! Live entertainment is a cornerstone of what makes Lonell's special. Wednesday: Live Jazz 6-9pm. Friday: Live Jazz 6-9pm. Saturday: Karaoke 6-9pm. Sunday: Live Music during Brunch 1-5pm." }
        },
        {
          "@type": "Question",
          "name": "When is Sunday Brunch and what's special about it?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sunday Brunch is served from 11:00 AM to 5:00 PM with live music from 1:00 PM to 5:00 PM. Free champagne is included with your brunch. Seniors and government workers receive a 10% discount with valid ID." }
        },
        {
          "@type": "Question",
          "name": "Do you offer vegan or vegetarian soul food options?",
          "acceptedAnswer": { "@type": "Answer", "text": "We have several vegetarian-friendly sides including collard greens, red beans & rice, mac and cheese, string beans, black-eyed peas, yams, and cornbread. Please let your server know about any dietary restrictions and we will do our best to accommodate you." }
        },
        {
          "@type": "Question",
          "name": "Do you take reservations?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, we accept reservations. Call us at (323) 451-3104 or email reservations@lonellssoulfood.com to book a table. Walk-ins are also always welcome." }
        },
        {
          "@type": "Question",
          "name": "Does Lonell's offer takeout or delivery?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, we offer both takeout and delivery. Call (323) 451-3104 to place a takeout order or check your favorite delivery app." }
        },
        {
          "@type": "Question",
          "name": "What catering services do you offer?",
          "acceptedAnswer": { "@type": "Answer", "text": "We cater events of all sizes, from small family gatherings to corporate events and celebrations. Contact us at reservations@lonellssoulfood.com or call (323) 451-3104 for a custom quote." }
        },
        {
          "@type": "Question",
          "name": "Do you have private event spaces?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes! We offer two private event spaces: the Dining Room and the Small Room, each with a maximum capacity of 50 guests. Perfect for birthday parties, anniversaries, corporate dinners, community events, and celebrations. Email reservations@lonellssoulfood.com or call (323) 451-3104 to book." }
        },
        {
          "@type": "Question",
          "name": "Is Lonell's family-owned and Black-owned?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, Lonell's Soul Food Cuisine is a proud Black-owned, family-owned business in South Los Angeles. 'A Place of Love' is our promise. Every guest is treated like family." }
        },
        {
          "@type": "Question",
          "name": "What's the parking situation?",
          "acceptedAnswer": { "@type": "Answer", "text": "Street parking is available and has been described by guests as 'a breeze.' There is also additional parking nearby." }
        },
        {
          "@type": "Question",
                  "name": "Is there a senior or government worker discount?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes! We offer a 10% discount for seniors and government workers with valid ID every day. Just let your server know when you order." }
        },
        {
          "@type": "Question",
          "name": "How does the SMS club work?",
          "acceptedAnswer": { "@type": "Answer", "text": "Text SOUL to (424) 295-8020 to join our SoulFood SMS Club. You will get exclusive offers, menu previews, and event invitations. Show your welcome text for 10% off your dinner. Offer expires 30 days after you join. Reply STOP anytime to cancel. Message and data rates may apply." }
        }
      ]
    })}></script>

    <!-- Page-level head slot (for per-page schema, etc.) -->
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[var(--color-surface-base)] text-[var(--color-text-primary)]">
    <!-- Navigation Overlay -->
    <NavOverlay />

    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-black focus:rounded focus:font-semibold">
      Skip to main content
    </a>

    <StickyHeader />

    <main id="main-content" class="relative">
      <TopMenuBar />
      {!isHome && <PageHeader background={headerBackground} backgrounds={headerBackgrounds} />}
      <slot />
    </main>

    <SiteFooter />

    <!-- Scroll-reveal observer, lightweight, no dependencies -->
    <script>
      if ("IntersectionObserver" in window && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
        );

        const revealed = document.querySelectorAll("[data-reveal]");
        const aboveFold = [];
        for (const el of revealed) {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight - 40) {
            aboveFold.push(el);
          } else {
            observer.observe(el);
          }
        }

        // Animate above-fold elements after a single frame so the hidden
        // state paints first, then the transition plays.
        requestAnimationFrame(() => {
          for (const el of aboveFold) {
            el.classList.add("visible");
          }
        });
      } else {
        // No observer or reduced motion. Make everything visible immediately.
        for (const el of document.querySelectorAll("[data-reveal]")) {
          el.classList.add("visible");
        }
      }
    </script>
  </body>
</html>
