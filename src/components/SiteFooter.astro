<script>
  const cta = document.getElementById("footer-cta-btn");
  if (cta) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          cta.classList.remove("opacity-0", "translate-y-6");
          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(cta);
  }
</script>
