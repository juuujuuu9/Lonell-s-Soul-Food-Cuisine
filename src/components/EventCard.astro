---
import EventScheduleIcon from "./EventScheduleIcon.astro";

export interface Props {
  title: string;
  date: string;
  description: string;
  type: "jazz" | "karaoke" | "brunch";
  href?: string;
  cta?: string;
}

const { title, date, description, type, href, cta = "Learn More" } = Astro.props;
---

<article class="event-card rounded-xl p-6 md:p-8">
  <div class="flex items-center justify-between w-full mb-3">
    <span class="text-xs tracking-[0.15em] uppercase text-[var(--color-accent)]">{date}</span>
    <EventScheduleIcon type={type} />
  </div>

  <h3 class="font-display text-xl md:text-2xl font-semibold mb-3">{title}</h3>

  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">{description}</p>

  {
    href ? (
      <a href={href} class="inline-flex items-center gap-2 text-xs tracking-wider uppercase text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">
        {cta}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="7" x2="11" y2="7" />
          <polyline points="7,3 11,7 7,11" />
        </svg>
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 text-xs tracking-wider uppercase text-[var(--color-text-muted)]">Coming Soon</span>
    )
  }
</article>
