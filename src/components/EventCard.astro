---
export interface Props {
  title: string;
  date: string;
  description: string;
  href?: string;
  cta?: string;
}

const { title, date, description, href, cta = "Learn More" } = Astro.props;
---

<article class="event-card rounded-xl p-6 md:p-8">
  <div class="flex items-center gap-2 mb-3">
    <div class="w-2 h-2 rounded-full bg-[var(--color-neon)] animate-pulse" />
    <span class="font-mono text-xs tracking-[0.15em] uppercase text-[var(--color-neon)]">{date}</span>
  </div>

  <h3 class="font-display text-xl md:text-2xl font-semibold mb-3">{title}</h3>

  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">{description}</p>

  {
    href ? (
      <a href={href} class="inline-flex items-center gap-2 font-mono text-xs tracking-wider uppercase text-[var(--color-neon)] hover:text-white transition-colors">
        {cta}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="7" x2="11" y2="7" />
          <polyline points="7,3 11,7 7,11" />
        </svg>
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 font-mono text-xs tracking-wider uppercase text-[var(--color-text-muted)]">Coming Soon</span>
    )
  }
</article>
