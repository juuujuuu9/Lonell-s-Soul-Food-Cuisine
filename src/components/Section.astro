---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  className?: string;
  wide?: boolean;
}

const { eyebrow, title, description, className = "", wide = false } = Astro.props;
---

<section class={`section-padding ${className}`}>
  <div class={wide ? "max-w-6xl mx-auto" : "max-w-4xl mx-auto"}>
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight">{title}</h2>
    {description && (
      <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">{description}</p>
    )}
    <slot />
  </div>
</section>
