---
const links = [
  { href: "/menu", label: "MENU" },
  { href: "/contact", label: "CONTACT" },
  { href: "tel:+13234513104", label: "CALL TO ORDER", class: "nav-overlay-cta" },
];
---

<nav id="main-nav-overlay" class="nav-overlay" aria-label="Main navigation">
  <div class="text-center">
    {
      links.map((link) => (
        <a
          href={link.href}
          class={link.class === "nav-overlay-cta"
            ? "nav-overlay-cta"
            : "block py-3 hover:text-[var(--color-accent)] transition-colors"}
          data-nav-link
        >
          {link.label}
        </a>
      ))
    }
  </div>
</nav>
