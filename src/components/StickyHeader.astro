---
import HeaderOrderButton from "./HeaderOrderButton.astro";
import MenuToggleButton from "./MenuToggleButton.astro";
---

<div
  id="sticky-header"
  class="fixed top-0 left-0 right-0 z-[110] -translate-y-full transition-transform duration-300"
>
  <div class="sticky-header-inner flex items-center justify-between h-14 md:h-16 px-4 md:px-6 bg-[var(--color-surface-card)]/80 backdrop-blur-sm">
    <a href="/" class="sticky-header-logo inline-flex shrink-0" aria-label="Lonell's Soul Food, Home">
      <picture>
        <source
          srcset="/media/images/lonells-logo.webp 1x, /media/images/lonells-logo@2x.webp 2x"
          type="image/webp"
        />
        <img
          src="/media/images/lonells-logo.jpg"
          alt="Lonell's Soul Food Cuisine, A Place of Love"
          width="882"
          height="377"
          class="h-9 md:h-11 w-auto"
          loading="eager"
        />
      </picture>
    </a>
    <div class="sticky-header-actions flex items-center gap-2 md:gap-3">
      <HeaderOrderButton />
      <a
        href="tel:+13234513104"
        class="sticky-header-phone hidden md:flex items-center gap-1.5 px-3 py-2 text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors"
        aria-label="Call us at (323) 451-3104"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        <span>(323) 451-3104</span>
      </a>
      <MenuToggleButton toggleId="menu-toggle" labelId="menu-label" iconId="menu-icon" />
    </div>
  </div>
</div>

<script>
  const headerEl = document.getElementById("sticky-header");
  const topMenuBar = document.getElementById("top-menu-bar");
  const overlay = document.querySelector(".nav-overlay");
  if (!headerEl || !overlay) throw new Error();

  const toggles = ["menu-toggle", "top-menu-toggle"]
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLButtonElement => el instanceof HTMLButtonElement);

  const labels = ["menu-label", "top-menu-label"]
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el instanceof HTMLElement);

  const icons = ["menu-icon", "top-menu-icon"]
    .map((id) => document.getElementById(id))
    .filter((el): el is SVGElement => el instanceof SVGElement);

  const THRESHOLD = window.innerHeight / 4;
  let ticking = false;
  let overlayOpen = false;

  const menuIcon = '<line x1="2" y1="4" x2="14" y2="4" /><line x1="2" y1="8" x2="14" y2="8" /><line x1="2" y1="12" x2="14" y2="12" />';
  const closeIcon = '<line x1="3" y1="3" x2="13" y2="13" /><line x1="13" y1="3" x2="3" y2="13" />';

  const syncTopMenuBar = (stickyVisible) => {
    if (!topMenuBar) return;
    const hide = stickyVisible || overlayOpen;
    topMenuBar.classList.toggle("opacity-0", hide);
    topMenuBar.classList.toggle("pointer-events-none", hide);
  };

  const updateHeader = () => {
    const stickyVisible = overlayOpen || window.scrollY > THRESHOLD;

    if (stickyVisible) {
      headerEl.classList.remove("-translate-y-full");
      headerEl.classList.add("translate-y-0");
    } else {
      headerEl.classList.add("-translate-y-full");
      headerEl.classList.remove("translate-y-0");
    }

    syncTopMenuBar(stickyVisible);
    ticking = false;
  };

  const setMenuOpen = (open) => {
    overlayOpen = open;
    overlay.classList.toggle("open", open);
    headerEl.classList.toggle("is-nav-open", open);
    toggles.forEach((toggle) => toggle.setAttribute("aria-expanded", String(open)));
    labels.forEach((label) => { label.textContent = open ? "CLOSE" : "MENU"; });
    icons.forEach((icon) => { icon.innerHTML = open ? closeIcon : menuIcon; });
    document.body.classList.toggle("nav-open", open);
    updateHeader();
  };

  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }, { passive: true });

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => setMenuOpen(!overlayOpen));
  });

  overlay.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  updateHeader();
</script>
