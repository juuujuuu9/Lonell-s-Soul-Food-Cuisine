---
export interface PageHeaderBackground {
  webp: string;
  webp2x?: string;
  jpg: string;
  alt?: string;
  position?: "center" | "top";
  mobile?: {
    webp: string;
    webp2x?: string;
    jpg: string;
  };
}

export interface Props {
  background?: PageHeaderBackground;
  backgrounds?: PageHeaderBackground[];
}

const { background, backgrounds } = Astro.props;
const randomBackgrounds = backgrounds && backgrounds.length > 1 ? backgrounds : undefined;
const resolvedBackground = background ?? backgrounds?.[0];
---

<header
  class:list={[
    "relative flex flex-col overflow-hidden",
    resolvedBackground ? "min-h-[44vh] md:min-h-[36vh] lg:min-h-[32vh] bg-[var(--color-surface-base)]" : "min-h-[32vh] md:min-h-[25vh]",
  ]}
>
  {
    resolvedBackground && (
      <>
        <picture
          id={randomBackgrounds ? "page-header-background" : undefined}
          class="absolute inset-0 -bottom-px min-h-full"
          aria-hidden="true"
        >
          {
            resolvedBackground.mobile && (
              <>
                <source
                  media="(max-width: 767px)"
                  srcset={`${resolvedBackground.mobile.webp} 1x${resolvedBackground.mobile.webp2x ? `, ${resolvedBackground.mobile.webp2x} 2x` : ""}`}
                  type="image/webp"
                />
                <source media="(max-width: 767px)" srcset={resolvedBackground.mobile.jpg} type="image/jpeg" />
              </>
            )
          }
          <source
            data-header-webp-source
            srcset={randomBackgrounds ? undefined : `${resolvedBackground.webp} 1x${resolvedBackground.webp2x ? `, ${resolvedBackground.webp2x} 2x` : ""}`}
            type="image/webp"
          />
          <img
            data-header-img
            src={randomBackgrounds ? undefined : resolvedBackground.jpg}
            alt={randomBackgrounds ? "" : (resolvedBackground.alt ?? "")}
            class:list={[
              "absolute inset-0 h-[calc(100%+1px)] w-full object-cover",
              resolvedBackground.position === "top" ? "object-top" : "object-center",
            ]}
            loading="eager"
            fetchpriority="high"
          />
        </picture>
        {
          randomBackgrounds && (
            <script
              is:inline
              set:html={`(function(){var backgrounds=${JSON.stringify(randomBackgrounds)};var bg=backgrounds[Math.floor(Math.random()*backgrounds.length)];var picture=document.getElementById("page-header-background");if(!picture)return;var webp=picture.querySelector("[data-header-webp-source]");var img=picture.querySelector("[data-header-img]");if(webp){webp.srcset=bg.webp+" 1x"+(bg.webp2x?", "+bg.webp2x+" 2x":"");}if(img){img.src=bg.jpg;img.alt=bg.alt||"";}})();`}
            />
          )
        }
        <div
          class="absolute inset-0 -bottom-px bg-gradient-to-b from-black/45 via-black/60 to-[#0a0a0a] pointer-events-none"
          aria-hidden="true"
        />
        <div class="absolute inset-0 -bottom-px bg-gradient-to-br from-[var(--color-brand-amber)]/5 to-transparent pointer-events-none" aria-hidden="true" />
        <div class="absolute inset-x-0 bottom-0 h-px bg-[#0a0a0a]" aria-hidden="true" />
      </>
    )
  }

  <div class="h-14 md:h-16 shrink-0 relative z-10" aria-hidden="true"></div>
  <div
    class:list={[
      "relative z-10 flex flex-1 items-center justify-center px-4",
      resolvedBackground ? "pb-14 md:pb-16 lg:pb-12" : "pb-6 md:pb-8",
    ]}
  >
    <a href="/" class="inline-flex max-md:translate-x-[2.1%]" aria-label="Lonell's Soul Food, Home">
      <picture>
        <source
          srcset="/media/images/lonells-gold-logo.webp 1x, /media/images/lonells-gold-logo@2x.webp 2x"
          type="image/webp"
        />
        <img
          src="/media/images/lonells-gold-logo.png"
          alt="Lonell's Soul Food Cuisine, A Place of Love"
          width="1200"
          height="894"
          class="max-md:w-[17.1875rem] md:w-64 lg:w-80 h-auto drop-shadow-[0_4px_24px_rgba(0,0,0,0.45)]"
          loading="eager"
        />
      </picture>
    </a>
  </div>
</header>
