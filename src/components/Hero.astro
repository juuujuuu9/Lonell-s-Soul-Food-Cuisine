---
export interface Props {
  showScrollIndicator?: boolean;
}

const { showScrollIndicator = true } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden" data-hero>
  <!-- Background image -->
  <picture class="absolute inset-0" aria-hidden="true">
    <source srcset="/media/images/wide-bar-lg.webp" media="(max-width: 1920px)" type="image/webp" />
    <source srcset="/media/images/wide-bar.webp" type="image/webp" />
    <source srcset="/media/images/wide-bar-lg.jpg" media="(max-width: 1920px)" type="image/jpeg" />
    <img
      src="/media/images/wide-bar.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </picture>
  <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/65 to-black/90 pointer-events-none" />
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-brand-amber)]/5 to-transparent pointer-events-none" />

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- Logo — fades in first, more deliberate -->
    <h1 class="mb-8 inline-flex items-center justify-center animate-fade-in-up" style="animation-delay: 0.15s">
      <picture>
        <source
          srcset="/media/images/lonells-logo.webp 1x, /media/images/lonells-logo@2x.webp 2x"
          type="image/webp"
        />
        <img
          src="/media/images/lonells-logo.jpg"
          alt="Lonell's Soul Food Cuisine — A Place of Love"
          width="882"
          height="377"
          class="w-72 md:w-96 lg:w-[28rem] h-auto drop-shadow-[0_4px_24px_rgba(0,0,0,0.5)]"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </h1>

    <p class="text-lg md:text-xl text-[var(--color-text-primary)] max-w-3xl mx-auto mb-4 leading-relaxed uppercase animate-fade-in-up" style="animation-delay: 0.35s">
      Authentic Soul Food<br />with Live Jazz in South LA
    </p>
    <p class="text-lg md:text-xl text-[var(--color-accent)] max-w-2xl mx-auto mb-10 leading-relaxed italic font-display animate-fade-in-up" style="animation-delay: 0.45s">
      "A Place of Love"
    </p>

    <!-- Key Value Props -->
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mb-10 text-sm text-[var(--color-text-primary)] tracking-wider uppercase animate-fade-in-up" style="animation-delay: 0.55s">
      <span>Live Music</span>
      <span class="w-1 h-1 rounded-full bg-[var(--color-text-primary)]" />
      <span>Sunday Brunch</span>
      <span class="w-1 h-1 rounded-full bg-[var(--color-text-primary)]" />
      <span>Private Events</span>
      <span class="w-1 h-1 rounded-full bg-[var(--color-text-primary)]" />
      <span>Takeout &amp; Delivery</span>
    </div>

    <!-- CTAs — hierarchical: primary Order Now, secondary phone, tertiary links -->
    <div class="flex flex-col items-center gap-6 animate-fade-in-up" style="animation-delay: 0.65s">
      <a
        href="tel:+13234513104"
        class="inline-flex items-center px-8 md:px-10 py-3.5 md:py-4 bg-[var(--color-brand-amber)] text-black font-bold text-base md:text-lg rounded-full hover:bg-[var(--color-brand-amber-light)] transition-all min-h-[56px] shadow-lg shadow-[var(--color-brand-amber)]/20 hover:shadow-xl hover:shadow-[var(--color-brand-amber)]/30 active:scale-[0.98]"
      >
        Order Now
      </a>
      <a
        href="tel:+13234513104"
        class="inline-flex items-center px-6 py-2.5 border border-[var(--color-border)] text-[var(--color-text-primary)] text-sm rounded-full hover:bg-[var(--color-surface-hover)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        (323) 451-3104
      </a>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm">
        <a href="/menu" class="text-[var(--color-text-primary)] hover:text-[var(--color-neon)] transition-colors underline underline-offset-2 decoration-[var(--color-border-subtle)]">
          View Our Menu
        </a>
        <span class="text-[var(--color-text-primary)]">·</span>
        <a href="/events" class="text-[var(--color-text-primary)] hover:text-[var(--color-neon)] transition-colors underline underline-offset-2 decoration-[var(--color-neon-subtle)]">
          Live Music Schedule
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  {
    showScrollIndicator && (
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
        <span class="text-[10px] tracking-[0.2em] uppercase text-[var(--color-text-primary)]">Scroll</span>
        <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-text-primary)] animate-bounce">
          <line x1="8" y1="4" x2="8" y2="16" />
          <polyline points="2,12 8,18 14,12" />
        </svg>
      </div>
    )
  }
</section>
