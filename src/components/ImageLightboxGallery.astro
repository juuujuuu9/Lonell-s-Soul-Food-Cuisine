---
export interface GalleryPhoto {
  webp: string;
  webp2x: string;
  jpg: string;
  full: string;
  width: number;
  height: number;
  alt: string;
}

interface Props {
  photos: GalleryPhoto[];
  class?: string;
  mobileCarousel?: boolean;
}

const { photos, class: className = "", mobileCarousel = false } = Astro.props;
const galleryId = `lightbox-${Math.random().toString(36).slice(2, 9)}`;
---

<div class={className} data-lightbox-gallery={galleryId}>
  {
    mobileCarousel ? (
      <div class="gallery-carousel" aria-label="Restaurant photo gallery">
        {
          photos.map((photo, index) => (
            <button
              type="button"
              class="gallery-carousel-slide group block overflow-hidden rounded-xl border border-[var(--color-border-subtle)] cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
              data-lightbox-open={index}
              aria-label={`View larger: ${photo.alt}`}
            >
              <picture class="block">
                <source srcset={`${photo.webp} 1x, ${photo.webp2x} 2x`} type="image/webp" />
                <img
                  src={photo.jpg}
                  alt={photo.alt}
                  width={photo.width}
                  height={photo.height}
                  class="w-full h-full object-cover aspect-[4/3] transition-transform duration-300 group-active:scale-105"
                  loading="lazy"
                />
              </picture>
            </button>
          ))
        }
      </div>
    ) : null
  }

  <div class={`gallery-grid ${mobileCarousel ? "gallery-grid-responsive" : "gallery-grid-static"}`}>
    {
      photos.map((photo, index) => (
        <button
          type="button"
          class="gallery-tile group"
          data-lightbox-open={index}
          aria-label={`View larger: ${photo.alt}`}
        >
          <div class="gallery-tile-frame">
            <picture>
              <source srcset={`${photo.webp} 1x, ${photo.webp2x} 2x`} type="image/webp" />
              <img
                src={photo.jpg}
                alt={photo.alt}
                width={photo.width}
                height={photo.height}
                class="gallery-tile-image"
                loading="lazy"
              />
            </picture>
          </div>
        </button>
      ))
    }
  </div>
</div>

<dialog id={galleryId} class="lightbox-dialog" aria-label="Image gallery lightbox">
  <div class="lightbox-shell">
    <header class="lightbox-toolbar">
      {
        photos.length > 1 ? (
          <p data-lightbox-counter class="text-xs tracking-[0.15em] uppercase text-[var(--color-text-muted)]">
            1 / {photos.length}
          </p>
        ) : (
          <span />
        )
      }
      <button
        type="button"
        class="lightbox-control"
        data-lightbox-close
        aria-label="Close gallery"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </header>

    <div class="lightbox-stage">
      {
        photos.length > 1 && (
          <button type="button" class="lightbox-control lightbox-nav" data-lightbox-prev aria-label="Previous image">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <polyline points="15 18 9 12 15 6" />
            </svg>
          </button>
        )
      }

      <figure class="lightbox-figure">
        <div class="lightbox-track-viewport" data-lightbox-viewport>
          <div class="lightbox-track" data-lightbox-track>
            {
              photos.map((photo) => (
                <div class="lightbox-slide">
                  <img src={photo.full} alt={photo.alt} loading="lazy" decoding="async" draggable="false" />
                </div>
              ))
            }
          </div>
        </div>
      </figure>

      {
        photos.length > 1 && (
          <button type="button" class="lightbox-control lightbox-nav" data-lightbox-next aria-label="Next image">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </button>
        )
      }
    </div>

    <footer class="lightbox-footer">
      {
        photos.length > 1 && (
          <button type="button" class="lightbox-control lightbox-nav-mobile" data-lightbox-prev aria-label="Previous image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <polyline points="15 18 9 12 15 6" />
            </svg>
          </button>
        )
      }
      <p data-lightbox-caption class="text-sm text-[var(--color-text-secondary)] leading-relaxed"></p>
      {
        photos.length > 1 && (
          <button type="button" class="lightbox-control lightbox-nav-mobile" data-lightbox-next aria-label="Next image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </button>
        )
      }
    </footer>
  </div>
</dialog>

<script define:vars={{ photos, galleryId }}>
  const dialog = document.getElementById(galleryId);
  const gallery = document.querySelector(`[data-lightbox-gallery="${galleryId}"]`);
  if (!dialog || !gallery) throw new Error();

  const captionEl = dialog.querySelector("[data-lightbox-caption]");
  const counterEl = dialog.querySelector("[data-lightbox-counter]");
  const closeBtn = dialog.querySelector("[data-lightbox-close]");
  const viewportEl = dialog.querySelector("[data-lightbox-viewport]");
  const trackEl = dialog.querySelector("[data-lightbox-track]");
  if (!captionEl || !closeBtn || !viewportEl || !trackEl) throw new Error();

  let currentIndex = 0;
  let currentOffset = 0;
  let dragStartX = 0;
  let dragStartY = 0;
  let dragStartOffset = 0;
  let dragStartTime = 0;
  let isDragging = false;
  let dragAxis = null;

  const getSlideWidth = () => viewportEl.clientWidth;

  const indexToOffset = (index) => -index * getSlideWidth();

  const setTrackTransform = (offset, animate) => {
    trackEl.classList.toggle("is-snapping", animate);
    trackEl.style.transform = `translate3d(${offset}px, 0, 0)`;
  };

  const updateMeta = () => {
    const photo = photos[currentIndex];
    captionEl.textContent = photo.alt;
    if (counterEl) counterEl.textContent = `${currentIndex + 1} / ${photos.length}`;
  };

  const goToIndex = (index, animate = true) => {
    currentIndex = ((index % photos.length) + photos.length) % photos.length;
    currentOffset = indexToOffset(currentIndex);
    setTrackTransform(currentOffset, animate);
    updateMeta();
  };

  gallery.querySelectorAll("[data-lightbox-open]").forEach((button) => {
    button.addEventListener("click", () => {
      goToIndex(Number(button.getAttribute("data-lightbox-open")), false);
      dialog.showModal();
    });
  });

  closeBtn.addEventListener("click", () => dialog.close());

  dialog.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });

  dialog.addEventListener("keydown", (event) => {
    if (event.key === "Escape") dialog.close();
    if (photos.length <= 1) return;
    if (event.key === "ArrowLeft") goToIndex(currentIndex - 1);
    if (event.key === "ArrowRight") goToIndex(currentIndex + 1);
  });

  dialog.querySelectorAll("[data-lightbox-prev]").forEach((button) => {
    button.addEventListener("click", (event) => {
      event.stopPropagation();
      goToIndex(currentIndex - 1);
    });
  });

  dialog.querySelectorAll("[data-lightbox-next]").forEach((button) => {
    button.addEventListener("click", (event) => {
      event.stopPropagation();
      goToIndex(currentIndex + 1);
    });
  });

  if (photos.length > 1) {
    const endDrag = (event) => {
      if (!isDragging) return;
      isDragging = false;
      dragAxis = null;
      viewportEl.classList.remove("is-dragging");

      const slideWidth = getSlideWidth();
      const dragDelta = currentOffset - dragStartOffset;
      const absDelta = Math.abs(dragDelta);
      const elapsed = Date.now() - dragStartTime;

      // Velocity-based: if flicked fast enough and far enough, advance
      const velocity = absDelta / Math.max(elapsed, 1);
      const fastFlick = velocity > 0.5 && absDelta > slideWidth * 0.15;
      // Position-based threshold: dragged more than 30% of slide width
      const pastThreshold = absDelta > slideWidth * 0.3;

      let targetIndex = currentIndex;

      if (pastThreshold || fastFlick) {
        targetIndex = dragDelta < 0 ? currentIndex + 1 : currentIndex - 1;
      } else {
        // Snap back to current
        targetIndex = currentIndex;
      }

      goToIndex(targetIndex, true);
    };

    viewportEl.addEventListener("pointerdown", (event) => {
      if (event.button !== 0) return;

      isDragging = true;
      dragAxis = null;
      dragStartX = event.clientX;
      dragStartY = event.clientY;
      dragStartOffset = currentOffset;
      dragStartTime = Date.now();
      trackEl.classList.remove("is-snapping");
      viewportEl.classList.add("is-dragging");
      viewportEl.setPointerCapture(event.pointerId);
    });

    viewportEl.addEventListener("pointermove", (event) => {
      if (!isDragging) return;

      const deltaX = event.clientX - dragStartX;
      const deltaY = event.clientY - dragStartY;

      if (!dragAxis) {
        if (Math.abs(deltaX) < 8 && Math.abs(deltaY) < 8) return;
        dragAxis = Math.abs(deltaX) >= Math.abs(deltaY) ? "x" : "y";
        if (dragAxis === "y") {
          isDragging = false;
          viewportEl.classList.remove("is-dragging");
          viewportEl.releasePointerCapture(event.pointerId);
          return;
        }
      }

      event.preventDefault();
      currentOffset = dragStartOffset + deltaX;

      // Only clamp/overshoot when at first or last slide
      const min = indexToOffset(photos.length - 1);
      const max = 0;
      if (currentOffset > max) {
        currentOffset = max + (currentOffset - max) * 0.25;
      } else if (currentOffset < min) {
        currentOffset = min + (currentOffset - min) * 0.25;
      }

      setTrackTransform(currentOffset, false);
    });

    viewportEl.addEventListener("pointerup", endDrag);
    viewportEl.addEventListener("pointercancel", endDrag);

    window.addEventListener("resize", () => {
      if (!dialog.open) return;
      goToIndex(currentIndex, false);
    });
  } else {
    updateMeta();
  }
</script>

<style>
  .gallery-carousel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  @media (min-width: 768px) {
    .gallery-carousel {
      display: none;
    }
  }

  .gallery-carousel::-webkit-scrollbar {
    display: none;
  }

  .gallery-carousel-slide {
    flex: 0 0 85%;
    scroll-snap-align: start;
  }

  .gallery-grid {
    gap: 1rem;
  }

  .gallery-grid-static {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  @media (min-width: 640px) {
    .gallery-grid-static {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .gallery-grid-responsive {
    display: none;
  }

  @media (min-width: 768px) {
    .gallery-grid-responsive {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid-responsive {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .gallery-tile {
    display: block;
    width: 100%;
    min-width: 0;
    padding: 0;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border-subtle);
    background: transparent;
    cursor: pointer;
  }

  .gallery-tile:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gallery-tile-frame {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-card);
  }

  .gallery-tile-frame picture {
    position: absolute;
    inset: 0;
    display: block;
  }

  .gallery-tile-image {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .gallery-tile:hover .gallery-tile-image,
  .gallery-tile:active .gallery-tile-image {
    transform: scale(1.05);
  }

  @media (min-width: 640px) {
    .gallery-grid {
      align-items: stretch;
    }

    .gallery-grid .gallery-tile-frame {
      aspect-ratio: 3 / 4;
    }

    .gallery-grid .gallery-tile-image {
      object-fit: contain;
      object-position: center;
    }
  }

  .lightbox-dialog {
    width: 100vw;
    height: 100dvh;
    max-width: 100vw;
    max-height: 100dvh;
    margin: 0;
    padding: 0;
    border: 0;
    overflow: hidden;
    background: transparent;
    overscroll-behavior: none;
  }

  .lightbox-dialog::backdrop {
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(8px);
  }

  .lightbox-shell {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    width: 100%;
    height: 100dvh;
    padding: 1rem;
    box-sizing: border-box;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .lightbox-shell {
      padding: 1.25rem 1.5rem;
      gap: 1rem;
    }
  }

  .lightbox-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2.75rem;
  }

  .lightbox-stage {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    min-height: 0;
  }

  @media (min-width: 640px) {
    .lightbox-stage {
      gap: 1.25rem;
    }
  }

  .lightbox-figure {
    min-width: 0;
    min-height: 0;
    height: 100%;
    margin: 0;
  }

  .lightbox-track-viewport {
    width: 100%;
    height: 100%;
    overflow: hidden;
    touch-action: pan-y;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .lightbox-track-viewport.is-dragging {
    touch-action: none;
    cursor: grabbing;
  }

  .lightbox-track {
    display: flex;
    height: 100%;
    will-change: transform;
    touch-action: none;
  }

  .lightbox-track.is-snapping {
    transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .lightbox-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    height: 100%;
    box-sizing: border-box;
  }

  .lightbox-slide img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.75rem;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
    pointer-events: none;
  }

  .lightbox-footer {
    min-height: 2.75rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    padding-inline: 0.5rem;
  }

  .lightbox-footer p {
    max-width: 42rem;
    margin: 0;
    justify-self: center;
  }

  .lightbox-nav-mobile {
    display: inline-flex;
  }

  @media (min-width: 640px) {
    .lightbox-footer {
      display: flex;
      justify-content: center;
    }

    .lightbox-nav-mobile {
      display: none;
    }
  }

  .lightbox-control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: rgba(20, 20, 20, 0.85);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .lightbox-control:hover {
    background: var(--color-surface-hover);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .lightbox-control:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 639px) {
    .lightbox-stage {
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: minmax(0, 1fr) auto;
    }

    .lightbox-nav {
      display: none;
    }

    .lightbox-figure {
      grid-row: 1;
    }
  }
</style>
